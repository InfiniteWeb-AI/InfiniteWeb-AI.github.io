    {
      "id": "blend_workshop",
      "name": "Blend Your Own Bottle Workshop",
      "slug": "blend-workshop",
      "experience_type": "blend_workshop",
      "short_description": "Hands-on blending seminar where you create and bottle your own custom red blend.",
      "full_description": "Work side-by-side with our winemaking team to learn how individual lots are blended into the final wine. You will taste through component wines, experiment with your own blend, and bottle a custom-labeled 750ml bottle to take home.",
      "duration_minutes": 120,
