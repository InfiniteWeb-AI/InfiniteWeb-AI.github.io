    {
      "id": "reserve_tasting",
      "name": "Reserve Cellar Tasting",
      "slug": "reserve-tasting",
      "experience_type": "tasting",
      "short_description": "Seated tasting of limited-production reserve and library wines in our private cellar.",
      "full_description": "Relax in our candlelit cellar for an intimate, seated tasting of reserve and library selections. Your host will guide you through five small-lot wines, including single-vineyard bottlings and older vintages from our library, paired with artisan cheeses.",
      "duration_minutes": 60,
      "base_price_per_adult": 60,
      "base_price_per_child": 0,
      "location": "Marlow Estate Cellar, Sonoma, CA",
