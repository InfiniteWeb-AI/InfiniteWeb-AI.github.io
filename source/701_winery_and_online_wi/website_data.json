  "static_pages": [
    {
      "id": "about",
      "filename": "about.html",
      "title": "Our Story",
      "body_html": "<h1>Our Story</h1><p>Founded by the Marlow family, Marlow Estate Winery grows and crafts wines from sustainably farmed vineyards along the coastal hillsides.</p><p>Over three generations, our philosophy has remained simple: farm with respect for the land, harvest at peak flavor, and let each vineyard speak clearly in the glass.</p><p>Today, our team combines traditional techniques with thoughtful innovation, producing small-lot wines that reflect the character of our soils and climate.</p>",
      "created_at": "2024-01-10T09:00:00Z",
      "updated_at": "2025-10-20T14:30:00Z"
    },
    {
      "id": "help",
      "filename": "help.html",
      "title": "Help & Policies",
      "body_html": "<h1>Help &amp; Policies</h1><p>Here you will find answers to common questions about ordering, shipping, returns, and wine club memberships.</p><h2>Shipping</h2><p>We ship to most U.S. states where legal. Standard shipping typically arrives within 5–7 business days.</p><h2>Returns</h2><p>If you receive a damaged or flawed bottle, please contact us within 30 days for a replacement or refund.</p>",
      "created_at": "2024-01-15T10:15:00Z",
      "updated_at": "2025-09-05T11:45:00Z"
    },
    {
      "id": "privacy",
      "filename": "privacy.html",
      "title": "Privacy Policy",
      "body_html": "<h1>Privacy Policy</h1><p>We respect your privacy and are committed to protecting your personal information.</p><p>We collect data you provide when placing orders, joining the wine club, or subscribing to our newsletter, and we use it only to fulfill your requests and improve your experience.</p><p>You may request access to or deletion of your data at any time by contacting our support team.</p>",
      "created_at": "2024-01-20T08:30:00Z",
      "updated_at": "2025-08-25T13:00:00Z"
    },
    {
      "id": "contact_info",
      "filename": "contact.html",
      "title": "Contact Us",
      "body_html": "<h1>Contact Us</h1><p>Have a question about our wines, club, or visiting the estate? We would love to hear from you.</p><p>Email: <a href=\"mailto:info@marlowestate.com\">info@marlowestate.com</a><br/>Phone: (555) 123-4567<br/>Address: 123 Vineyard Lane, Sonoma, CA 95476</p>",
      "created_at": "2024-02-01T09:45:00Z",
      "updated_at": "2025-07-12T16:20:00Z"
    }
  ],
  "tour_experiences": [
    {
      "id": "vineyard_tour",
      "name": "Estate Vineyard Tour",
      "slug": "vineyard-tour",
      "experience_type": "vineyard_tour",
      "short_description": "Guided walking tour through our estate vineyards followed by a hosted tasting.",
      "full_description": "Join one of our wine educators for a 60–75 minute guided walk through the estate vineyards. Learn about our organic and sustainable farming practices, our unique microclimates, and how we handcraft each wine. The experience concludes with a seated tasting of current releases on the terrace overlooking the vines.",
      "duration_minutes": 75,
      "base_price_per_adult": 45,
      "base_price_per_child": 15,
      "location": "Marlow Estate Vineyard, Sonoma, CA",
      "image_url": "https://www.norcalvineyards.com/wp-content/uploads/2020/05/NorCalVineyards_West_Sonoma_DJI_0789.jpg",
