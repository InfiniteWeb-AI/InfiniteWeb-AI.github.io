  "faq_items": [
    {
      "id": "faq_payment_options",
      "question": "What payment options are available for buying this domain?",
      "answer": "You can purchase the domain using major credit and debit cards, PayPal, and in some cases bank transfer or wire. For Buy Now purchases, your payment is processed immediately. For lease-to-own plans, we set up an automatic monthly charge using your selected payment method. All payments are processed over an encrypted, secure checkout.",
      "category": "payment_options",
      "slug": "payment-options",
      "isExpandedDefault": false,
      "displayOrder": 10
    },
    {
      "id": "faq_installments",
      "question": "Can I pay for the domain in installments (lease-to-own)?",
      "answer": "Yes. If lease-to-own is available, you can choose a monthly payment plan during checkout. You will see several plan lengths with different monthly prices. After your final payment is completed, full ownership of the domain is transferred to you. You can also usually pay off the remaining balance early at any time.",
      "category": "payment_options",
      "slug": "installment-plans",
      "isExpandedDefault": false,
      "displayOrder": 20
    },
    {
      "id": "faq_transfer_process",
      "question": "How does the domain transfer process work after I pay?",
      "answer": "Once your payment is confirmed, we initiate the transfer to your preferred registrar. For most purchases, you will receive an email with either a transfer authorization code (EPP code) or push instructions for the seller’s registrar. After you follow those steps, the domain will appear in your account at the receiving registrar. Transfers typically complete within 1–5 business days, depending on the registrars involved.",
      "category": "domain_transfer_process",
      "slug": "domain-transfer-process",
      "isExpandedDefault": false,
      "displayOrder": 30
    },
    {
      "id": "faq_transfer_timing",
      "question": "How long will it take to receive the domain after I complete checkout?",
      "answer": "Most domain transfers are completed within a few hours to 1–2 business days after payment. In rare cases, such as cross-registrar transfers with additional verification requirements, it may take up to 5–7 business days. We will keep you updated by email until the domain appears in your registrar account.",
      "category": "domain_transfer_process",
      "slug": "transfer-timing",
      "isExpandedDefault": false,
      "displayOrder": 40
    },
    {
      "id": "faq_refunds",
      "question": "Do you offer refunds or cancellations after purchasing the domain?",
      "answer": "Because domain names are unique digital assets, completed sales are generally final and non-refundable once the transfer has started or been completed. In limited situations (for example, payment processing errors or if the seller cannot deliver the domain), we may issue a refund according to our Terms & Conditions. If you believe you qualify for a refund, please use the Contact Support form below to reach our team.",
      "category": "refunds_cancellations",
      "slug": "refunds-and-cancellations",
      "isExpandedDefault": false,
      "displayOrder": 50
    },
    {
      "id": "faq_general_support",
      "question": "I still have questions. How can I contact support?",
      "answer": "If you have any questions about payment options, lease plans, or the transfer process that are not answered here, you can contact our support team using the form in the Support section below. Provide as much detail as possible about the domain, your budget, and your timeline so we can assist you quickly.",
      "category": "general",
      "slug": "contact-support",
      "isExpandedDefault": false,
      "displayOrder": 60
    }
  ],
