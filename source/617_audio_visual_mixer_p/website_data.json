  "reviews": [
    {
      "id": "rev_001",
      "product_id": "mixer_live_clean_12ch",
      "rating": 5,
      "title": "Great for small live gigs",
      "body": "Used this mixer for a few bar shows and a church event. Preamps are clean, EQ is musical, and the built-in effects sound better than expected at this price.",
      "author_display_name": "StageSoundChris",
      "created_at": "2025-06-10T19:32:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_002",
      "product_id": "mixer_live_clean_12ch",
      "rating": 4,
      "title": "Solid value and easy to use",
      "body": "We run a 4-piece band through this. Plenty of headroom and the layout is straightforward. Would love individual channel compressors, but for the money it's excellent.",
      "author_display_name": "BandDad",
      "created_at": "2025-12-01T15:10:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_003",
      "product_id": "mixer_live_clean_12ch",
      "rating": 5,
      "title": "Reliable live mixer",
      "body": "No issues after six months of weekly use. Faders still feel smooth and all channels work perfectly. Zero hiss through our powered speakers.",
      "author_display_name": "FOH_Tech",
      "created_at": "2026-01-15T21:45:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_004",
      "product_id": "mixer_live_noise_14ch",
      "rating": 5,
      "title": "Feature-packed live console",
      "body": "Lots of channels, flexible routing, and the built-in FX are surprisingly good. Works great for our rehearsal space and small outdoor shows.",
      "author_display_name": "GarageGrooves",
      "created_at": "2024-09-02T18:05:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_005",
      "product_id": "mixer_live_noise_14ch",
      "rating": 4,
      "title": "Great sound and routing options",
      "body": "We upgraded from a simple 8-channel board. This has plenty of aux sends and groups. Overall sound is clean and clear with nice headroom.",
      "author_display_name": "AudioCraft",
      "created_at": "2025-04-11T11:22:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_006",
      "product_id": "mixer_live_noise_14ch",
      "rating": 5,
      "title": "Perfect for our live stream rig",
      "body": "Running 10 mics plus a stereo playback feed with no problems. USB interface works flawlessly with our streaming PC.",
      "author_display_name": "StreamCityChurch",
      "created_at": "2025-09-20T09:55:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_007",
      "product_id": "mixer_live_noise_14ch",
      "rating": 4,
      "title": "Good mixer but slight hiss on some channels",
      "body": "Overall this is a very capable live sound mixer and the built-in effects are excellent. However, I do hear a low-level hiss on two of the mic channels when the gain is pushed. It's not a deal breaker for loud shows, but in a quiet room the noise is noticeable.",
      "author_display_name": "QuietRoomSound",
      "created_at": "2026-02-20T16:30:00Z",
      "mentions_noise": true
    },
    {
      "id": "rev_008",
      "product_id": "mixer_av_8ch_budget",
      "rating": 4,
      "title": "Best budget 8-channel mixer I found",
      "body": "For under $300 this mixer is hard to beat. Metal chassis, enough inputs for our duo, and it sounds clean through our powered speakers.",
      "author_display_name": "OpenMicHost",
      "created_at": "2025-07-05T13:12:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_009",
      "product_id": "mixer_av_8ch_budget",
      "rating": 5,
      "title": "Great little board for rehearsal",
      "body": "We use every channel and it still feels like it has headroom. No hum or buzz even in our old practice room with sketchy power.",
      "author_display_name": "BasementBand89",
      "created_at": "2025-11-18T20:00:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_010",
      "product_id": "mixer_bt_usb_16ch",
      "rating": 4,
      "title": "Solid mixer with Bluetooth convenience",
      "body": "Bluetooth makes it easy to play break music from a phone. USB recording works fine to capture our sets. I did notice a tiny background hum at extreme gain, but at normal levels it's quiet.",
      "author_display_name": "ClubResident",
      "created_at": "2025-08-22T17:40:00Z",
      "mentions_noise": true
    },
    {
      "id": "rev_011",
      "product_id": "mixer_bt_usb_16ch",
      "rating": 4,
      "title": "Lots of channels in a compact frame",
      "body": "Plenty of inputs and the layout is intuitive. Fans of digital mixers might miss recallable scenes, but for an analog-style board with Bluetooth and USB it does the job.",
      "author_display_name": "StageHandPro",
      "created_at": "2026-01-28T10:05:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_012",
      "product_id": "mixer_premium_finance",
      "rating": 5,
      "title": "Pro-level sound without the pro price",
      "body": "The preamps and EQ sound like much more expensive desks. Using it for both live shows and studio sessions with great results.",
      "author_display_name": "StudioFOH",
      "created_at": "2025-03-15T12:15:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_013",
      "product_id": "mixer_premium_finance",
      "rating": 4,
      "title": "Excellent mixer, steep learning curve",
      "body": "Tons of routing and effects options. It took a few days to really understand the workflow, but once dialed in it's incredibly flexible and quiet.",
      "author_display_name": "RigBuilder",
      "created_at": "2025-10-09T22:30:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_014",
      "product_id": "mixer_fx_analog_12ch",
      "rating": 4,
      "title": "Great analog board with usable FX",
      "body": "Built-in effects sound good enough for small venues, and the analog feel is exactly what I wanted. No noticeable hiss through our mains.",
      "author_display_name": "AnalogOnly",
      "created_at": "2024-12-02T14:00:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_015",
      "product_id": "mixer_fx_analog_12ch",
      "rating": 5,
      "title": "Rock-solid for weekend gigs",
      "body": "We run 5 vocal mics, drums, and keys through this every weekend. Built-in effects save space in the rack and the mixer has been totally reliable.",
      "author_display_name": "WeekendWarrior",
      "created_at": "2025-09-01T19:25:00Z",
      "mentions_noise": false
    },
    {
      "id": "rev_016",
      "product_id": "mixer_fx_digital_16ch",
      "rating": 4,
      "title": "Digital flexibility with built-in effects",
      "body": "Scenes, per-channel EQ, and multiple FX engines in one box. The fan is audible in a silent room but there's no hum or hiss in the audio path.",
      "author_display_name": "TourBusTech",
      "created_at": "2025-05-19T08:45:00Z",
      "mentions_noise": true
    },
    {
      "id": "rev_017",
      "product_id": "mixer_fx_digital_16ch",
      "rating": 4,
      "title": "Powerful mixer for church and live stream",
      "body": "Handles our worship band and multiple monitor mixes easily. The built-in effects and dynamics save us from needing extra rack gear.",
      "author_display_name": "SanctuarySound",
      "created_at": "2026-02-05T11:55:00Z",
      "mentions_noise": false
    }
  ],
