  "faq_articles": [
    {
      "id": "faq_security_deposit",
      "category": "billing_payments",
      "question": "Is there a security deposit?",
      "answer": "Yes. We require a $75 refundable security deposit per space at the time of move-in. The deposit is held to cover any unpaid rent, fees, or damages. As long as your account is paid in full and your space is left clean and undamaged, the full $75 security deposit is automatically refunded to your original payment method within 10 business days after you move out.",
      "is_active": true,
      "sort_order": 10
    },
    {
      "id": "faq_autopay",
      "category": "billing_payments",
      "question": "How does autopay work?",
      "answer": "Autopay automatically charges your preferred payment method on your monthly due date so you never miss a payment. You can enable or disable autopay anytime from the My Account > Billing & Autopay section. We currently support credit and debit cards for autopay. Changes made at least one day before your due date will apply to the upcoming charge.",
      "is_active": true,
      "sort_order": 20
    },
    {
      "id": "faq_change_reservation",
      "category": "reservations",
      "question": "Can I change my move-in date or switch to a different space after reserving?",
      "answer": "Yes. You can modify most reservations online before your move-in date. From the My Account dashboard, go to My Reservations, select the reservation you want to change, and use the Edit or Change Unit & Date option. You will see available spaces and pricing for your new date. If the new space costs more, you will be shown the updated monthly rate before confirming the change.",
      "is_active": true,
      "sort_order": 30
    },
    {
      "id": "faq_gate_hours",
      "category": "access",
      "question": "What are your gate hours?",
      "answer": "Standard gate access hours are 6:00 AM to 10:00 PM, 7 days a week, including holidays. For customers who need additional flexibility, we offer an optional 24/7 Gate Access add-on at select locations. Office hours vary by facility, so please check the facility details page for specific office times.",
      "is_active": true,
      "sort_order": 40
    },
    {
      "id": "faq_vehicles_allowed",
      "category": "general",
      "question": "What types of vehicles can I store?",
      "answer": "Our facilities are designed to accommodate a wide range of vehicles, including Class A, B, and C motorhomes, travel trailers, fifth wheels, camper vans, toy haulers, boats on trailers, personal watercraft, and some commercial vehicles. Each space has a listed maximum length and type (RV or boat), so please choose a space that matches your vehicle and length, including the trailer and hitch.",
      "is_active": true,
      "sort_order": 50
    },
    {
      "id": "faq_security_features",
      "category": "security",
      "question": "What security features do your facilities have?",
      "answer": "Most of our facilities feature computerized gate access, perimeter fencing, bright LED lighting, and 24/7 digital video surveillance. Facility managers perform regular walkthroughs of the property. While no storage facility can guarantee complete security, we invest heavily in multiple layers of protection to help safeguard your RV or boat.",
      "is_active": true,
      "sort_order": 60
    }
  ],
