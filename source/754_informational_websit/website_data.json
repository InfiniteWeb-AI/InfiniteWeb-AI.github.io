  "diseases": [
    {
      "id": "disease_fusarium_wilt",
      "code": "fusarium_wilt",
      "name": "Fusarium wilt",
      "description": "Soil-borne fungal disease that causes yellowing and wilting of tomato plants, often listed as F or F1/F2 resistance in seed catalogs."
    },
    {
      "id": "disease_verticillium_wilt",
      "code": "verticillium_wilt",
      "name": "Verticillium wilt",
      "description": "Fungal disease that causes V-shaped lesions and wilting, commonly abbreviated as V resistance."
    },
    {
      "id": "disease_early_blight",
      "code": "early_blight",
      "name": "Early blight",
      "description": "Foliar disease caused by Alternaria fungi, producing target-like leaf spots and defoliation early in the season."
    },
    {
      "id": "disease_late_blight",
      "code": "late_blight",
      "name": "Late blight",
      "description": "Serious disease caused by Phytophthora infestans, leading to rapid dark lesions on leaves and fruit, especially in cool, wet weather."
    },
    {
      "id": "disease_tmv",
      "code": "tobacco_mosaic_virus",
      "name": "Tobacco mosaic virus (TMV)",
      "description": "Viral disease that causes mottled, distorted leaves and reduced yields; resistance often labeled as T or TMV."
    },
    {
      "id": "disease_general_tolerance",
      "code": "general_disease_tolerance",
      "name": "General disease tolerance",
      "description": "Broad, non-specific tolerance to common tomato diseases, often expressed as improved overall plant health and resilience."
    }
  ],
