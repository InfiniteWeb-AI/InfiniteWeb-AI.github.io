  "reviews": [
    {
      "id": "rev_001",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 5,
      "title": "Visible smoothing after a few weeks",
      "content": "I’ve been using this retinol serum every other night for a month and my fine lines around the eyes are noticeably softer. No major irritation as long as I moisturize well.",
      "author_display_name": "CaraM",
      "created_at": "2025-11-15T09:24:00Z"
    },
    {
      "id": "rev_002",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 5,
      "title": "Gentle but effective retinol",
      "content": "I have slightly sensitive skin and this is one of the few retinol formulas that didn’t burn or peel my face. I started twice a week and worked up to nightly.",
      "author_display_name": "James",
      "created_at": "2025-12-01T18:10:00Z"
    },
    {
      "id": "rev_003",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 4,
      "title": "Great for texture",
      "content": "My forehead bumps are smoother and my pores look smaller. Took about 3 weeks to notice a change. I only wish the bottle were bigger.",
      "author_display_name": "SkincareNerd",
      "created_at": "2026-01-05T07:42:00Z"
    },
    {
      "id": "rev_004",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 4,
      "title": "Mild peeling at first",
      "content": "The first week I had some flakiness, but backing off to every third night helped. Now I can use it nightly with a rich moisturizer and my skin looks brighter.",
      "author_display_name": "Lina",
      "created_at": "2026-01-20T21:05:00Z"
    },
    {
      "id": "rev_005",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 4,
      "title": "Solid mid-strength retinol",
      "content": "Not the strongest I’ve tried, but perfect for maintaining results without irritation. I use it in the evening only and always pair with SPF in the morning.",
      "author_display_name": "Patrick D",
      "created_at": "2025-10-10T14:30:00Z"
    },
    {
      "id": "rev_006",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 4,
      "title": "Helps with acne marks",
      "content": "My post-acne marks faded faster than usual. I use a pea-sized amount at night and follow with a calming cream. No breakouts triggered.",
      "author_display_name": "Maya",
      "created_at": "2025-09-18T11:12:00Z"
    },
    {
      "id": "rev_007",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 5,
      "title": "Worth the price",
      "content": "The texture is silky and layers nicely under my night moisturizer. After 6 weeks my skin tone is more even and my smile lines are softer.",
      "author_display_name": "Olivia",
      "created_at": "2025-08-02T20:55:00Z"
    },
    {
      "id": "rev_008",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 3,
      "title": "A bit strong for my dry skin",
      "content": "Even with moisturizer I experienced some tightness and redness when I tried using it nightly. Now I stick to twice a week and it’s fine.",
      "author_display_name": "Alex R",
      "created_at": "2025-07-25T06:47:00Z"
    },
    {
      "id": "rev_009",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 5,
      "title": "Love this for nighttime routine",
      "content": "This has become a staple in my evening routine. No breakouts, smoother cheeks, and my makeup sits better during the day.",
      "author_display_name": "Jordan",
      "created_at": "2025-06-15T16:03:00Z"
    },
    {
      "id": "rev_010",
      "product_id": "serum_luminique_retinol_renew_night",
      "rating": 4,
      "title": "Good introductory retinol",
      "content": "If you’re new to retinol, this is a nice starting point. Start slow and moisturize a lot—worked well for my combination skin.",
      "author_display_name": "Nina",
      "created_at": "2025-05-30T09:18:00Z"
    },
    {
      "id": "rev_011",
      "product_id": "shampoo_evermane_sulfate_free_daily",
      "rating": 5,
      "title": "Best sulfate-free shampoo I’ve tried",
      "content": "Cleans my oily roots without stripping the ends. I wash every other day and my scalp feels less itchy than with my old shampoo.",
      "author_display_name": "Beth",
      "created_at": "2025-09-01T13:22:00Z"
    },
    {
      "id": "rev_012",
      "product_id": "shampoo_evermane_sulfate_free_daily",
      "rating": 4,
      "title": "Gentle and lathers well",
      "content": "Pleasant light scent and no sulfates. It doesn’t leave residue and my hair feels soft. Took off one star because I wish the bottle were pump-style.",
      "author_display_name": "Chris",
      "created_at": "2025-12-28T19:40:00Z"
    },
    {
      "id": "rev_013",
      "product_id": "moist_luminique_sensitive_gel_cream",
      "rating": 5,
      "title": "Holy grail for my sensitive skin",
      "content": "Truly fragrance-free and no stinging at all. Lightweight but surprisingly hydrating. I use it morning and night over my serum.",
      "author_display_name": "Emily K",
      "created_at": "2025-04-12T08:05:00Z"
    },
    {
      "id": "rev_014",
      "product_id": "moist_luminique_sensitive_gel_cream",
      "rating": 4,
      "title": "Calming and non-greasy",
      "content": "Helps calm redness on my cheeks and absorbs quickly. Great under sunscreen, and it doesn’t cause any breakouts.",
      "author_display_name": "Samira",
      "created_at": "2025-08-19T17:33:00Z"
    },
    {
      "id": "rev_015",
      "product_id": "giftset_noirpetal_her_glow_trio",
      "rating": 5,
      "title": "Perfect birthday gift",
      "content": "Bought this set for my sister and she loved all three products. The packaging is gorgeous and feels very luxe for the price.",
      "author_display_name": "Tanya",
      "created_at": "2025-11-25T10:48:00Z"
    },
    {
      "id": "rev_016",
      "product_id": "giftset_noirpetal_her_glow_trio",
      "rating": 4,
      "title": "Beautiful presentation",
      "content": "Came gift-ready with a pretty box. The mini cleanser, serum, and cream are all decent sizes. Only wish there were more scent-free options.",
      "author_display_name": "Rachel",
      "created_at": "2026-02-10T15:02:00Z"
    },
    {
      "id": "rev_017",
      "product_id": "foundation_velour_spf_beige_1",
      "rating": 5,
      "title": "Natural finish and good SPF",
      "content": "Medium coverage that still looks like skin. Shade Beige matches me perfectly and I love that it has built-in SPF for daytime.",
      "author_display_name": "Dani",
      "created_at": "2025-03-22T12:15:00Z"
    },
    {
      "id": "rev_018",
      "product_id": "foundation_velour_spf_beige_1",
      "rating": 4,
      "title": "Great everyday foundation",
      "content": "Blends easily with a sponge and doesn’t cling to dry patches. Lasts most of the workday with a little powder touch-up.",
      "author_display_name": "Jess",
      "created_at": "2025-06-05T09:55:00Z"
    },
    {
      "id": "rev_019",
      "product_id": "foundation_velour_spf_beige_2",
      "rating": 4,
      "title": "Nice for combo skin",
      "content": "Good medium coverage and the Beige shade runs slightly warmer than expected but still works. SPF is a bonus.",
      "author_display_name": "Priya",
      "created_at": "2025-07-07T18:27:00Z"
    },
    {
      "id": "rev_020",
      "product_id": "moist_noirpetal_radiance_face_cream",
      "rating": 5,
      "title": "Luxurious night cream",
      "content": "Rich texture without feeling heavy. I wake up with plump, glowy skin and it layers nicely over my serum and eye cream.",
      "author_display_name": "Helena",
      "created_at": "2025-10-05T22:11:00Z"
    }
