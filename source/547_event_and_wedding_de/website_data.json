  "faq_items": [
    {
      "id": "wedding_cancellation_policy",
      "category_id": "weddings",
      "question": "What is your wedding cancellation policy?",
      "answer": "You may cancel your wedding decor booking in writing at any time. Cancellations made 60 or more days before the event date receive a full refund of payments made, minus a non‑refundable 10% design retainer. Cancellations between 30–59 days receive a 50% refund of the decor package total. Cancellations made less than 30 days before the event date are non‑refundable, but you may request a one‑time date change subject to availability and any applicable price differences.",
      "slug": "wedding-cancellation-policy",
      "is_active": true,
      "sort_order": 1
    },
    {
      "id": "wedding_reschedule_policy",
      "category_id": "weddings",
      "question": "Can I reschedule my wedding decor booking?",
      "answer": "Yes. You can request one complimentary date change up to 30 days before your original wedding date, subject to availability. Additional changes or changes requested within 30 days may incur a rescheduling fee, and package pricing will be updated to current rates if the new date falls in a higher‑demand season.",
      "slug": "wedding-reschedule-policy",
      "is_active": true,
      "sort_order": 2
    },
    {
      "id": "wedding_deposit_amount",
      "category_id": "weddings",
      "question": "How much is the deposit for wedding decoration packages?",
      "answer": "For wedding decoration packages, a 30% non‑refundable design retainer is required to secure your date. The remaining balance is due 14 days before the event. For last‑minute bookings within 30 days, the full amount is due at the time of booking.",
      "slug": "wedding-deposit-amount",
      "is_active": true,
      "sort_order": 3
    },
    {
      "id": "wedding_guest_count_changes",
      "category_id": "weddings",
      "question": "Can I adjust my guest count after booking a wedding package?",
      "answer": "You may increase or decrease your guest count up to 10 days before the wedding, as long as the new count is within the supported range of your selected package. Price adjustments will be applied per‑guest or per‑table where applicable, and an updated invoice will be issued for your approval.",
      "slug": "wedding-guest-count-changes",
      "is_active": true,
      "sort_order": 4
    },
    {
      "id": "wedding_includes_floral",
      "category_id": "weddings",
      "question": "Do your wedding packages include fresh floral centerpieces?",
      "answer": "Several of our standard and premium wedding packages include fresh floral centerpieces, while budget packages may feature high‑quality faux florals or simple greenery. Each package clearly lists whether fresh floral centerpieces are included and how many are provided based on your guest count.",
      "slug": "wedding-floral-centerpieces",
      "is_active": true,
      "sort_order": 5
    },
    {
      "id": "wedding_setup_teardown_times",
      "category_id": "weddings",
      "question": "What are your setup and teardown times for wedding decorations?",
      "answer": "Our team typically arrives 3–4 hours before guest arrival for setup and completes teardown within 1–2 hours after your event ends. Exact times are coordinated with your venue and listed in your confirmation schedule. Additional fees may apply for late‑night or after‑midnight teardown.",
      "slug": "wedding-setup-teardown-times",
      "is_active": true,
      "sort_order": 6
    },
    {
      "id": "corp_event_types",
      "category_id": "corporate_events",
      "question": "What types of corporate events do you handle?",
      "answer": "We design and install decor for conferences, annual meetings, product launches, holiday parties, award galas, trade show booths, and team‑building events. Custom proposals can be created for both small gatherings and large‑scale multi‑day events.",
      "slug": "corporate-event-types",
      "is_active": true,
      "sort_order": 1
    },
    {
      "id": "corp_consultation_process",
      "category_id": "corporate_events",
      "question": "How does the free corporate event consultation work?",
      "answer": "During the free consultation, a decor specialist reviews your event goals, budget, timeline, and venue details. We discuss decor, lighting, and add‑on services, then send a tailored proposal and estimate. Consultations can be held via video call or phone at your preferred date and time.",
      "slug": "corporate-consultation-process",
      "is_active": true,
      "sort_order": 2
    },
    {
      "id": "corp_branding_options",
      "category_id": "corporate_events",
      "question": "Can you incorporate our company branding into the decor?",
      "answer": "Yes. We can match brand colors, integrate logos into backdrops and signage, and design custom centerpieces or lighting effects that reflect your visual identity. Share your brand guidelines before the consultation so we can prepare tailored concepts.",
      "slug": "corporate-branding-options",
      "is_active": true,
      "sort_order": 3
    },
    {
      "id": "general_payment_methods",
      "category_id": "general",
      "question": "What payment methods do you accept?",
      "answer": "We accept major credit and debit cards, ACH bank transfers, and most digital wallet payments. For corporate clients, approved purchase orders and invoicing may be available. All payments are processed securely through our online checkout.",
      "slug": "payment-methods",
      "is_active": true,
      "sort_order": 1
    },
    {
      "id": "general_service_areas",
      "category_id": "general",
      "question": "Which areas do you serve?",
      "answer": "We currently serve the greater Chicago area and surrounding suburbs, as well as select nearby cities for larger events. For venues outside our standard service radius, travel fees may apply. Contact us with your venue address for a custom quote.",
      "slug": "service-areas",
      "is_active": true,
      "sort_order": 2
    },
    {
      "id": "general_last_minute_bookings",
      "category_id": "general",
      "question": "Do you offer last-minute decor packages or rush bookings?",
      "answer": "Yes. Our Last‑Minute Deals section highlights decor packages with confirmed availability within the next 30–60 days at special rates. Rush bookings are accepted based on inventory and staffing, and full payment is required at the time of booking.",
      "slug": "last-minute-deals-info",
      "is_active": true,
      "sort_order": 3
    },
    {
      "id": "general_changes_to_order",
      "category_id": "general",
      "question": "Can I make changes to my order after checkout?",
      "answer": "Minor changes, such as adjusting quantities or swapping a rental item, are usually possible up to 7 days before your event, subject to inventory availability. Contact our support team with your order number as soon as possible to request any modifications.",
      "slug": "changes-to-order",
      "is_active": true,
      "sort_order": 4
    },
    {
      "id": "general_contact_response_time",
      "category_id": "general",
      "question": "How long does it take to get a response after submitting the contact form?",
      "answer": "We respond to most inquiries within one business day. Time‑sensitive questions about events occurring within the next 7 days are prioritized, and you will typically hear back within a few hours during our normal support hours.",
      "slug": "contact-response-time",
      "is_active": true,
      "sort_order": 5
    }
  ],
