      "composer": "Michael Tan",
      "year_composed": 2015,
      "style": "contemporary",
      "description": "Rhythmic, pulsing harmonies evoke the movement of northern lights in this mixed-voice piece."
    },
    {
      "id": "rp_before_the_dawn",
      "title": "Before the Dawn",
      "composer": "Katherine Liu",
      "year_composed": 2008,
      "style": "contemporary",
      "description": "A reflective a cappella anthem featuring layered entrances and an expressive alto line."
    },
    {
      "id": "rp_cantate_domino",
      "title": "Cantate Domino",
      "composer": "Giovanni Croce",
      "year_composed": 1590,
      "style": "classical",
      "description": "Renaissance motet in Latin with imitative polyphony and joyful rhythmic vitality."
    },
    {
      "id": "rp_city_rhythm",
      "title": "City Rhythm",
      "composer": "James Porter",
      "year_composed": 2012,
      "style": "jazz",
      "description": "A jazz-influenced piece with syncopated vocal lines and optional scat solos."
    },
    {
      "id": "rp_dona_nobis_pacem_round",
      "title": "Dona Nobis Pacem (Round)",
      "composer": "Traditional",
      "year_composed": 1800,
      "style": "sacred",
      "description": "A traditional canon for three-part voices, often sung as a benediction."
    },
    {
      "id": "rp_evening_rain",
      "title": "Evening Rain",
      "composer": "Sara Holm",
      "year_composed": 2001,
      "style": "contemporary",
      "description": "Gentle contemporary choral work with piano, using raindrop-like ostinatos under a flowing melody."
    },
    {
      "id": "rp_family_song",
