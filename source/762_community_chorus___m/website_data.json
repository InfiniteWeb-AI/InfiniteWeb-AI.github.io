  "repertoire_pieces": [
    {
      "id": "rp_a_bridge_of_stars",
      "title": "A Bridge of Stars",
      "composer": "Elena Martínez",
      "year_composed": 2003,
      "style": "contemporary",
      "description": "A luminous contemporary work with shimmering cluster chords and a slow, arching melodic line."
    },
    {
      "id": "rp_aurora_skies",
