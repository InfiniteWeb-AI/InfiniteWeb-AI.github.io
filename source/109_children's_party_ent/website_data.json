{
  "faq_items": [
    {
      "id": "faq_deposit_policy",
      "question": "How much is the booking deposit and when is it due?",
      "answer": "We require a 25% deposit at the time of booking to reserve your party date and time. The remaining balance is due 3 days before your event. Your deposit is applied toward the total party cost and can be paid securely online by credit or debit card. If you need to make changes to your booking, you can adjust your package or add-ons up until 5 days before the event.\n\nReady to get started? Use the link below to open our booking form and check availability.",
      "category": "deposit",
      "slug": "booking-deposit-policy",
      "order_index": 1,
      "is_active": true,
      "has_booking_link": true,
      "booking_link_label": "Start a Booking",
      "booking_link_url": "booking.html?source=faq_deposit"
    },
    {
      "id": "faq_payment_methods",
      "question": "What payment methods do you accept?",
      "answer": "We accept all major credit cards (Visa, MasterCard, American Express, Discover), debit cards, and our own gift cards. Full payment can be completed online through our secure checkout. At this time, we do not accept cash or checks for deposits or final balances.",
      "category": "payment",
      "slug": "payment-methods",
      "order_index": 2,
      "is_active": true,
      "has_booking_link": false,
      "booking_link_label": "",
      "booking_link_url": ""
    },
    {
      "id": "faq_change_cancel",
      "question": "What is your cancellation and rescheduling policy?",
      "answer": "You may reschedule your party once at no additional charge up to 7 days before your event date, subject to availability. Cancellations made 14 or more days before the event are eligible for a full refund of the deposit. Cancellations made within 14 days of the event are non-refundable, but you may apply your deposit as credit toward a future party within 12 months.",
      "category": "cancellation",
      "slug": "cancellation-and-rescheduling",
      "order_index": 3,
      "is_active": true,
      "has_booking_link": false,
      "booking_link_label": "",
      "booking_link_url": ""
    },
    {
      "id": "faq_group_size",
      "question": "How many children can each party package accommodate?",
      "answer": "Each party package lists a recommended maximum number of children based on the activities and entertainer. Most of our standard packages are designed for 8–15 children, but we also offer options for larger groups. If you expect more children than the listed capacity, please contact us or add an extra helper or entertainer as an add-on so we can ensure a smooth experience.",
      "category": "booking",
      "slug": "party-group-size",
      "order_index": 4,
      "is_active": true,
      "has_booking_link": false,
      "booking_link_label": "",
      "booking_link_url": ""
    },
    {
      "id": "faq_travel_fees",
      "question": "Do you charge travel fees for entertainers?",
      "answer": "Travel within our core service area is included for many entertainers, while others may charge a small additional fee based on distance. When you enter your ZIP code on the Entertainers page, you will see which performers offer \"no travel fee\" in your area and any applicable travel charges before you book.",
      "category": "general",
      "slug": "entertainer-travel-fees",
      "order_index": 5,
      "is_active": true,
      "has_booking_link": false,
      "booking_link_label": "",
      "booking_link_url": ""
    },
    {
      "id": "faq_when_to_book",
      "question": "How far in advance should I book my party?",
      "answer": "We recommend booking at least 3–4 weeks in advance to secure your preferred date, time, and theme, especially during weekends and holiday periods. Last-minute bookings are sometimes available, so feel free to check our real-time availability through the booking form.",
      "category": "general",
      "slug": "when-to-book",
      "order_index": 6,
      "is_active": true,
      "has_booking_link": false,
      "booking_link_label": "",
      "booking_link_url": ""
    }
  ],
