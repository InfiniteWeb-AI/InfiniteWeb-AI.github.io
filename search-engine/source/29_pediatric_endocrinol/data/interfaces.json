    {
      "name": "searchClassEvents",
      "description": "Search upcoming classes and events with filters for topic, date range, and optional minimum start time.",
      "parameters": [
        {
          "name": "topicCode",
          "type": "string",
          "required": false,
          "description": "High-level topic code, e.g., 'insulin_pump_education'."
        },
        {
          "name": "startDate",
          "type": "string",
          "required": true,
          "description": "ISO 8601 date string for start of search range (inclusive)."
        },
        {
          "name": "endDate",
          "type": "string",
          "required": true,
          "description": "ISO 8601 date string for end of search range (inclusive)."
        },
        {
          "name": "minStartTime",
          "type": "string",
          "required": false,
          "description": "Optional time-of-day threshold in 'HH:MM' 24-hour format (e.g., '17:00' to show classes at or after 5:00 PM)."
        },
        {
          "name": "onlyRegistrationOpen",
          "type": "boolean",
          "required": false,
          "default": true
        }
      ],
      "returns": {
        "type": "array",
        "items": "ClassEvent"
      },
      "relatedTasks": [
        "task_3"
      ]
    },
