{
  "interfaces": [
    {
      "name": "getHomePageContent",
      "description": "Get content for the homepage, including clinic overview, age ranges, key services, featured conditions, and primary calls-to-action (without URLs).",
      "parameters": [],
      "returns": {
        "type": "object",
        "properties": {
          "hero_title": {
            "type": "string"
          },
          "hero_subtitle": {
            "type": "string"
          },
          "age_range_text": {
            "type": "string",
            "description": "Text describing ages served, e.g., 'Newborn through 18 years'."
          },
          "services_highlight": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          },
          "featured_conditions": {
            "type": "array",
            "items": "Condition"
          },
          "primary_ctas": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string",
                  "description": "Internal key, e.g., 'appointments', 'prescription_refills', 'patient_forms', 'classes_events'."
                },
                "label": {
                  "type": "string"
                },
                "target_page": {
                  "type": "string",
                  "description": "Logical page key (no URL), e.g., 'appointments', 'prescription_refills', 'classes_events', 'patient_forms'."
                }
              }
            }
          }
        }
      },
      "relatedTasks": []
    },
    {
      "name": "getClinicAnnouncements",
      "description": "Get current clinic announcements for display on the homepage, such as holiday hours, urgent contact info, or new services.",
      "parameters": [],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "holiday_hours",
                "urgent_contact",
                "new_service",
                "general"
              ]
            },
            "start_datetime": {
              "type": "string",
              "description": "ISO 8601 datetime string when the announcement becomes active."
            },
            "end_datetime": {
              "type": "string",
              "description": "ISO 8601 datetime string when the announcement expires (optional)."
            },
            "is_active": {
              "type": "boolean"
            }
          }
        }
      },
      "relatedTasks": []
    },
    {
      "name": "getAppointmentPageOverview",
