    {
      "name": "getNewPatientVisitFormOptions",
      "description": "Get options and defaults for the 'Schedule a New Patient Visit' form, including reasons for visit and location choices.",
      "parameters": [],
      "returns": {
        "type": "object",
        "properties": {
          "reason_for_visit_options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string",
                  "description": "User-facing label, e.g., 'Type 1 Diabetes'."
                },
                "code": {
                  "type": "string",
                  "description": "Optional standardized code mapping to appointment_reason or condition, e.g., 'type_1_diabetes'."
                }
              }
            }
          },
          "location_options": {
            "type": "array",
            "items": "ClinicLocation"
          },
          "default_appointment_type": {
            "type": "string",
            "enum": [
              "new_patient",
              "follow_up",
              "telehealth"
            ],
            "description": "Usually 'new_patient' for this form."
          },
          "date_constraints": {
            "type": "object",
            "properties": {
              "earliest_date": {
                "type": "string",
                "description": "ISO 8601 date string for the earliest selectable date (e.g., today)."
              },
              "latest_date": {
                "type": "string",
                "description": "ISO 8601 date string for the farthest selectable date."
              }
            }
          }
        }
      },
      "relatedTasks": [
        "task_1"
      ]
    },
    {
      "name": "searchAvailableAppointmentSlots",
      "description": "Search available appointment slots by location, appointment type, and date range. Supports filtering to morning-only slots.",
      "parameters": [
        {
          "name": "locationId",
          "type": "string",
          "required": true,
          "description": "Clinic location to search appointments for.",
          "entityReference": {
            "entity": "ClinicLocation",
            "displayField": "name",
            "valueField": "id"
          }
        },
        {
          "name": "appointmentType",
          "type": "string",
          "required": true,
          "enum": [
            "new_patient",
            "follow_up",
            "telehealth"
          ]
        },
        {
          "name": "startDate",
          "type": "string",
          "required": true,
          "description": "ISO 8601 date string for the first date to search (inclusive)."
        },
        {
          "name": "endDate",
          "type": "string",
          "required": true,
          "description": "ISO 8601 date string for the last date to search (inclusive)."
        },
        {
          "name": "isMorningOnly",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "If true, return only slots where is_morning_slot is true (start time between 08:00 and 11:59)."
        }
      ],
      "returns": {
        "type": "array",
        "items": "AppointmentSlot"
      },
      "relatedTasks": [
        "task_1"
      ]
    },
    {
      "name": "submitAppointmentRequest",
      "description": "Submit a new appointment request for a child, optionally tied to a specific available appointment slot.",
      "parameters": [
        {
          "name": "appointmentType",
          "type": "string",
          "required": true,
          "enum": [
            "new_patient",
            "follow_up",
            "telehealth"
          ]
        },
        {
          "name": "reasonForVisitLabel",
          "type": "string",
          "required": true,
          "description": "Label selected in dropdown, e.g., 'Type 1 Diabetes'."
        },
        {
          "name": "reasonForVisitCode",
          "type": "string",
          "required": false,
          "enum": [
            "type_1_diabetes",
            "type_2_diabetes",
            "thyroid_disorder",
            "growth_concern",
            "puberty_concern",
            "other"
          ]
        },
        {
          "name": "locationId",
          "type": "string",
          "required": true,
          "description": "Clinic location for the visit.",
          "entityReference": {
            "entity": "ClinicLocation",
            "displayField": "name",
            "valueField": "id"
          }
        },
        {
          "name": "appointmentSlotId",
          "type": "string",
          "required": false,
          "description": "Selected AppointmentSlot id if user chose a specific time.",
          "entityReference": {
            "entity": "AppointmentSlot",
            "displayField": "start_datetime",
            "valueField": "id"
          }
        },
        {
          "name": "requestedStartDatetime",
          "type": "string",
          "required": true,
          "description": "Requested start datetime in ISO 8601 format (should match the slot start if one was chosen)."
        },
        {
          "name": "childName",
          "type": "string",
          "required": true
        },
        {
          "name": "childDateOfBirth",
          "type": "string",
          "required": true,
          "description": "Child date of birth in ISO 8601 date format (YYYY-MM-DD)."
        },
        {
          "name": "parentGuardianName",
          "type": "string",
          "required": true
        },
        {
          "name": "parentGuardianPhone",
          "type": "string",
          "required": true
        },
        {
          "name": "parentGuardianEmail",
          "type": "string",
          "required": true
        },
        {
          "name": "notes",
          "type": "string",
          "required": false,
          "description": "Optional notes or additional information for schedulers."
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "appointmentRequest": {
            "type": "AppointmentRequest"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "relatedTasks": [
        "task_1"
      ]
    },
