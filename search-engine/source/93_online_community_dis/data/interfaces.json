    {
      "name": "searchDiscussions",
      "description": "Search discussions by text query with filters and sorting, for use from the header search bar and search results page.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": true
        },
        {
          "name": "filters",
          "type": "object",
          "required": false,
          "properties": {
            "dateRange": {
              "type": "enum",
              "values": [
                "any_time",
                "last_24_hours",
                "last_7_days",
                "last_30_days",
                "last_6_months",
                "last_12_months"
              ]
            },
            "minReplies": {
              "type": "number",
              "required": false
            },
            "categorySlug": {
              "type": "enum",
              "required": false,
              "values": [
                "web_development",
                "product_feedback",
                "design",
                "career",
                "general_discussion"
              ]
            }
          }
        },
        {
          "name": "sortBy",
          "type": "enum",
          "required": false,
          "values": [
            "relevance",
            "newest",
            "oldest",
            "most_replied",
            "most_upvoted"
          ],
          "default": "relevance"
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "pageSize",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "discussion": "Discussion",
                "categoryName": {
                  "type": "string"
                },
                "tagNames": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "originalAuthorDisplayName": {
                  "type": "string"
                },
                "snippet": {
                  "type": "string"
                }
              }
            }
          },
          "totalCount": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "pageSize": {
            "type": "number"
          }
        }
      },
