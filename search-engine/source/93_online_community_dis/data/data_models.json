{
  "entities": [
    {
      "name": "Category",
      "storage_key": "categories",
      "description": "Discussion categories such as 'Web Development' and 'Product Feedback'",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "slug",
          "type": "enum",
          "required": true,
          "values": [
            "web_development",
            "product_feedback",
            "design",
            "career",
            "general_discussion"
          ]
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "discussionCount",
          "type": "number",
          "required": false
        },
        {
          "name": "lastActivityAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "position",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "name": "Discussion",
      "storage_key": "discussions",
      "description": "Top-level discussion thread within a category",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "categoryId",
          "type": "string",
          "required": true
        },
        {
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "name": "body",
          "type": "string",
          "required": true
        },
        {
          "name": "tagIds",
          "type": "array",
          "required": false,
          "description": "Array of Tag.id values attached to this discussion"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "replyCount",
          "type": "number",
          "required": false
        },
        {
          "name": "viewCount",
          "type": "number",
          "required": false
        },
        {
          "name": "score",
          "type": "number",
          "required": false,
          "description": "Upvote score of the original post"
        },
        {
          "name": "lastReplyAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "trendingScore",
          "type": "number",
          "required": false
        },
        {
          "name": "isSubscribed",
          "type": "boolean",
          "required": false,
          "description": "Whether the agent is subscribed to notifications for this discussion"
        },
        {
          "name": "isBookmarked",
          "type": "boolean",
          "required": false,
          "description": "Whether the agent has bookmarked this discussion"
        },
        {
          "name": "hasPoll",
          "type": "boolean",
          "required": false
        }
      ]
    },
    {
      "name": "Post",
      "storage_key": "posts",
      "description": "An individual post within a discussion, either the original post or a reply",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "discussionId",
          "type": "string",
          "required": true
        },
        {
          "name": "parentPostId",
          "type": "string",
          "required": false,
          "description": "If this is a reply to another post, the parent post id"
        },
        {
          "name": "isOriginalPost",
          "type": "boolean",
          "required": true
        },
        {
          "name": "authorDisplayName",
          "type": "string",
          "required": true
        },
        {
          "name": "authorProfileId",
          "type": "string",
          "required": false,
          "description": "MemberProfile.id for non-self authors"
        },
        {
          "name": "body",
          "type": "string",
          "required": true
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "upvoteCount",
          "type": "number",
          "required": false,
          "description": "Number of upvotes this post has received"
        },
        {
          "name": "likeCount",
          "type": "number",
          "required": false,
          "description": "Number of likes this post has received"
        },
        {
          "name": "replyCount",
          "type": "number",
          "required": false
        },
        {
          "name": "containsLink",
          "type": "boolean",
          "required": false
        },
        {
          "name": "links",
          "type": "array",
          "required": false,
          "description": "Array of hyperlink URLs contained in this post"
        }
      ]
    },
    {
      "name": "Reaction",
      "storage_key": "reactions",
      "description": "The current agent's reactions (upvotes or likes) on posts",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "postId",
          "type": "string",
          "required": true
        },
        {
          "name": "reactionType",
          "type": "enum",
          "required": true,
          "values": [
            "upvote",
            "like"
          ]
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        }
      ]
    },
    {
      "name": "Tag",
      "storage_key": "tags",
      "description": "Tag/topic used to categorize discussions and to be followed as a topic",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Display name such as 'CSS', 'React', 'UX Design'"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "followerCount",
          "type": "number",
          "required": false
        },
        {
          "name": "isFollowed",
          "type": "boolean",
          "required": false,
          "description": "Whether the agent is following this topic/tag"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "DiscussionTag",
      "storage_key": "discussion_tags",
      "description": "Join entity linking discussions and tags",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "discussionId",
          "type": "string",
          "required": true
        },
        {
          "name": "tagId",
          "type": "string",
          "required": true
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "MemberProfile",
      "storage_key": "member_profiles",
      "description": "Public profile for other community members (non-agent) shown when clicking a username",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "displayName",
          "type": "string",
          "required": true
        },
        {
          "name": "bio",
          "type": "string",
          "required": false
        },
        {
          "name": "avatarUrl",
          "type": "string",
          "required": false
        },
        {
          "name": "title",
          "type": "string",
          "required": false,
          "description": "Optional role or tagline such as 'Senior Developer'"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "discussionsCount",
          "type": "number",
          "required": false
        },
        {
          "name": "repliesCount",
          "type": "number",
          "required": false
        },
        {
          "name": "reputationScore",
          "type": "number",
          "required": false,
          "description": "Aggregate score from upvotes/likes on their posts"
        }
      ]
    },
    {
      "name": "PrivateMessage",
      "storage_key": "private_messages",
      "description": "Private messages sent by the agent to other members",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "recipientProfileId",
          "type": "string",
          "required": true
        },
        {
          "name": "recipientDisplayName",
          "type": "string",
          "required": true
        },
        {
          "name": "subject",
          "type": "string",
          "required": true
        },
        {
          "name": "body",
          "type": "string",
          "required": true
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "isRead",
          "type": "boolean",
          "required": false
        }
      ]
    },
    {
      "name": "AccountSettings",
      "storage_key": "account_settings",
      "description": "Single-agent account profile and preference settings",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "displayName",
          "type": "string",
          "required": false,
          "description": "Current display name, e.g., 'Alex UX Researcher'"
        },
        {
          "name": "bio",
          "type": "string",
          "required": false,
          "description": "20–30 word description of the agent's work and interests"
        },
        {
          "name": "timezone",
          "type": "enum",
          "required": false,
          "values": [
            "utc_minus_5",
            "utc",
            "utc_plus_1",
            "utc_plus_2"
          ]
        },
        {
          "name": "dailySummaryEnabled",
          "type": "boolean",
          "required": false,
          "description": "Whether daily summary / daily email digest notifications are enabled"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "ContentReport",
      "storage_key": "content_reports",
      "description": "Reports/flags submitted by the agent for specific posts (e.g., spam reports)",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "postId",
          "type": "string",
          "required": true
        },
        {
          "name": "reason",
          "type": "enum",
          "required": true,
          "values": [
            "spam",
            "harassment",
            "offensive",
            "off_topic",
            "other"
          ]
        },
        {
          "name": "note",
          "type": "string",
          "required": false,
          "description": "Optional additional details from the agent"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "values": [
            "submitted",
            "in_review",
            "resolved",
            "dismissed"
          ]
        }
      ]
    },
    {
      "name": "Poll",
      "storage_key": "polls",
      "description": "Poll attached to a discussion thread",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "discussionId",
          "type": "string",
          "required": true
        },
        {
          "name": "question",
          "type": "string",
          "required": true
        },
        {
          "name": "multipleChoiceAllowed",
          "type": "boolean",
          "required": true,
          "description": "Whether users can select more than one option"
        },
        {
          "name": "startAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "endAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "isClosed",
          "type": "boolean",
          "required": false
        }
      ]
    },
    {
      "name": "PollOption",
      "storage_key": "poll_options",
      "description": "Answer option within a poll",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "pollId",
          "type": "string",
          "required": true
        },
        {
          "name": "optionText",
          "type": "string",
          "required": true
        },
        {
          "name": "voteCount",
          "type": "number",
          "required": false,
          "description": "Total number of votes this option has received"
        }
      ]
    },
    {
      "name": "PollResponse",
      "storage_key": "poll_responses",
      "description": "The current agent's vote in a poll",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "pollId",
          "type": "string",
          "required": true
        },
        {
          "name": "optionId",
          "type": "string",
          "required": true
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        }
      ]
    }
  ],
  "relationships": [
    {
      "from": "Discussion",
      "to": "Category",
      "type": "belongs_to",
      "field": "categoryId"
    },
    {
      "from": "Post",
      "to": "Discussion",
      "type": "belongs_to",
      "field": "discussionId"
    },
    {
      "from": "Post",
      "to": "Post",
      "type": "belongs_to",
      "field": "parentPostId"
    },
    {
      "from": "Reaction",
      "to": "Post",
      "type": "belongs_to",
      "field": "postId"
    },
    {
      "from": "DiscussionTag",
      "to": "Discussion",
      "type": "belongs_to",
      "field": "discussionId"
    },
    {
      "from": "DiscussionTag",
      "to": "Tag",
      "type": "belongs_to",
      "field": "tagId"
    },
    {
      "from": "Post",
      "to": "MemberProfile",
      "type": "belongs_to",
      "field": "authorProfileId"
    },
    {
      "from": "PrivateMessage",
      "to": "MemberProfile",
      "type": "belongs_to",
      "field": "recipientProfileId"
    },
    {
      "from": "ContentReport",
      "to": "Post",
      "type": "belongs_to",
      "field": "postId"
    },
    {
      "from": "Poll",
      "to": "Discussion",
      "type": "belongs_to",
      "field": "discussionId"
    },
    {
      "from": "PollOption",
      "to": "Poll",
      "type": "belongs_to",
      "field": "pollId"
    },
    {
      "from": "PollResponse",
      "to": "Poll",
      "type": "belongs_to",
      "field": "pollId"
    },
    {
      "from": "PollResponse",
      "to": "PollOption",
      "type": "belongs_to",
      "field": "optionId"
    }
  ]
}