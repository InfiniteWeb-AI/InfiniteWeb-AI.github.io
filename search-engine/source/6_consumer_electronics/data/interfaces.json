    {
      "name": "listCategoryProducts",
      "description": "List products for a given category with filters, sorting, and pagination. Automatically respects selected vehicle when fitmentScope is set.",
      "parameters": [
        {
          "name": "categoryCode",
          "type": "enum",
          "required": true,
          "values": [
            "car_audio",
            "car_stereos_receivers",
            "speakers",
            "subwoofers",
            "amplifiers",
            "packages_bundles",
            "installation_accessories"
          ]
        },
        {
          "name": "filters",
          "type": "object",
          "required": false,
          "properties": {
            "minPrice": {
              "type": "number"
            },
            "maxPrice": {
              "type": "number"
            },
            "minRating": {
              "type": "number",
              "description": "Minimum average rating, e.g., 4 or 4.5."
            },
            "hasAppleCarPlay": {
              "type": "boolean"
            },
            "hasBluetooth": {
              "type": "boolean"
            },
            "hasBackupCameraInput": {
              "type": "boolean"
            },
            "freeShippingOnly": {
              "type": "boolean"
            },
            "includesWiringKit": {
              "type": "boolean"
            },
            "dinSize": {
              "type": "string",
              "description": "DIN size filter, e.g., 'single_din' or 'double_din'."
            },
            "speakerSizeInches": {
              "type": "number"
            },
            "speakerType": {
              "type": "string",
              "description": "Speaker type, e.g., 'component' or 'coaxial'."
            },
            "minRmsPower": {
              "type": "number"
            },
            "maxRmsPower": {
              "type": "number"
            },
            "channelCount": {
              "type": "number"
            },
            "productType": {
              "type": "string",
              "description": "Optional productType filter, e.g., 'car_stereo' or 'speaker_set'."
            },
            "accessoryType": {
              "type": "string",
              "description": "Installation accessory subtype, e.g., 'amp_wiring_kit', 'dash_kit', 'antenna_adapter'."
            },
            "bundleType": {
              "type": "string",
              "description": "Bundle subtype, e.g., 'subwoofer_amplifier_bundle'."
            },
            "isBundle": {
              "type": "boolean"
            },
            "onlyActive": {
              "type": "boolean",
              "description": "If true, only products with isActive = true are returned."
            }
          }
        },
        {
          "name": "fitmentScope",
          "type": "enum",
          "required": false,
          "values": [
            "none",
            "selected_vehicle_exact_fit",
            "selected_vehicle_partial_or_better"
          ],
          "default": "none",
          "description": "When not 'none', restricts results to products that fit the currently selected vehicle."
        },
        {
          "name": "sortBy",
          "type": "enum",
          "required": false,
          "values": [
            "relevance",
            "price_low_to_high",
            "price_high_to_low",
            "most_reviewed",
            "top_rated"
          ],
          "default": "relevance"
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "pageSize",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "product": {
                  "type": "Product",
                  "description": "Underlying product record."
                },
                "categoryName": {
                  "type": "string",
                  "description": "Display category name for this product."
                }
              }
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "page": {
                "type": "number"
              },
              "pageSize": {
                "type": "number"
              },
              "totalItems": {
                "type": "number"
              },
              "totalPages": {
                "type": "number"
              }
            }
          }
        }
      },
      "relatedTasks": [
        "task_1",
        "task_2",
        "task_3",
        "task_5",
        "task_6",
        "task_7",
        "task_8"
      ]
