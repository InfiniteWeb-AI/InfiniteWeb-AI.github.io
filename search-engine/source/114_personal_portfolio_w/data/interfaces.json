    {
      "name": "searchProjects",
      "description": "Search and filter projects for the Projects listing page, supporting keyword search, category, technologies/tags, languages, cloud provider, environment, and sorting.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": false,
          "description": "Free-text search query, e.g. 'microservices'."
        },
        {
          "name": "categoryIds",
          "type": "array",
          "items": {
            "type": "string"
          },
          "required": false,
          "description": "Filter by one or more project category IDs (e.g. DevOps).",
          "entityReference": {
            "entity": "ProjectCategory",
            "displayField": "name",
            "valueField": "id"
          }
        },
        {
          "name": "technologies",
          "type": "array",
          "items": {
            "type": "string"
          },
          "required": false,
          "description": "Filter by one or more technology names, e.g. ['Kubernetes', 'CI/CD', 'Terraform']."
        },
        {
          "name": "tags",
          "type": "array",
          "items": {
            "type": "string"
          },
          "required": false,
          "description": "Filter by domain tags, e.g. ['devops', 'microservices']."
        },
        {
          "name": "languageKeys",
          "type": "array",
          "items": {
            "type": "string"
          },
          "required": false,
          "description": "Filter by backend language keys, e.g. ['go', 'node_js']."
        },
        {
          "name": "cloudProviders",
          "type": "array",
          "items": {
            "type": "string"
          },
          "required": false,
          "description": "Filter by cloud provider keys, e.g. ['aws', 'gcp', 'azure']."
        },
        {
          "name": "environments",
          "type": "array",
          "items": {
            "type": "string"
          },
          "required": false,
          "description": "Filter by environment keys, e.g. ['production', 'staging']."
        },
        {
          "name": "usesKubernetes",
          "type": "boolean",
          "required": false,
          "description": "If true, only projects where uses_kubernetes is true are returned."
        },
        {
          "name": "usesTerraform",
          "type": "boolean",
          "required": false,
          "description": "If true, only projects where uses_terraform is true are returned."
        },
        {
          "name": "usesAws",
          "type": "boolean",
          "required": false,
          "description": "If true, only projects where uses_aws is true are returned."
        },
        {
          "name": "hasCiCd",
          "type": "boolean",
          "required": false,
          "description": "If true, only projects where has_ci_cd is true are returned."
        },
        {
          "name": "isMicroservices",
          "type": "boolean",
          "required": false,
          "description": "If true, only microservices-based projects (is_microservices = true) are returned."
        },
        {
          "name": "sortBy",
          "type": "string",
          "required": false,
          "default": "last_updated_desc",
          "description": "Sort order, e.g. 'last_updated_desc', 'start_date_desc', 'start_date_asc', 'relevance'."
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "pageSize",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "projects": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "project": {
                  "type": "Project"
                },
                "category_name": {
                  "type": "string"
                },
                "category_slug": {
                  "type": "string"
                },
                "is_in_comparison": {
                  "type": "boolean",
                  "description": "Indicates if this project is currently selected for comparison."
                }
              }
            }
          },
          "total_count": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "page_size": {
            "type": "number"
          }
        }
      },
      "relatedTasks": [
        "task_1",
        "task_2",
        "task_6"
      ]
    },
