    {
      "name": "searchGroupClassSessions",
      "description": "Search and filter scheduled group class sessions for the Programs & Group Classes page.",
      "parameters": [
        {
          "name": "audience",
          "type": "string",
          "required": false,
          "description": "Filter by audience; e.g., 'adult', 'junior', 'all_ages'."
        },
        {
          "name": "level",
          "type": "string",
          "required": false,
          "description": "Filter by level; e.g., 'beginner', 'intermediate', 'advanced', 'all_levels'."
        },
        {
          "name": "focus",
          "type": "string",
          "required": false,
          "description": "Filter by focus; e.g., 'cardio', 'strategy', 'match_play', 'technique', 'fitness', 'social', 'other'."
        },
        {
          "name": "startDate",
          "type": "string",
          "required": false,
          "description": "Earliest class start date in 'YYYY-MM-DD'."
        },
        {
          "name": "endDate",
          "type": "string",
          "required": false,
          "description": "Latest class start date in 'YYYY-MM-DD'."
        },
        {
          "name": "timeFrom",
          "type": "string",
          "required": false,
          "description": "Earliest local start time in 'HH:MM' 24h; e.g., '17:00' for 5pm."
        },
        {
          "name": "timeTo",
          "type": "string",
          "required": false,
          "description": "Latest local start time in 'HH:MM' 24h."
        },
        {
          "name": "minPrice",
          "type": "number",
          "required": false
        },
        {
          "name": "maxPrice",
          "type": "number",
          "required": false
        },
        {
          "name": "daysOfWeek",
          "type": "array",
          "required": false,
          "items": {
            "type": "string"
          },
          "description": "Optional list of day names; e.g., ['saturday','sunday']."
        },
        {
          "name": "limit",
          "type": "number",
          "required": false,
          "default": 50
        },
        {
          "name": "sortBy",
          "type": "string",
          "required": false,
          "default": "start_datetime",
          "description": "Sort field; e.g., 'price', 'start_datetime'."
        },
        {
          "name": "sortDirection",
          "type": "string",
          "required": false,
          "default": "asc",
