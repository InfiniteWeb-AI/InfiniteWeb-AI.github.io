                  "type": "string"
                },
                "start_datetime": {
                  "type": "string"
                },
                "end_datetime": {
                  "type": "string"
                },
                "price": {
                  "type": "number"
                },
                "remaining_spots": {
                  "type": "number"
                },
                "coach_id": {
                  "type": "string"
                },
                "coach_name": {
                  "type": "string"
                },
                "court_id": {
                  "type": "string"
