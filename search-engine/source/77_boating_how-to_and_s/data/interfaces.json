          "name": "boat_length_ft",
          "type": "number",
          "required": true
        },
        {
          "name": "boat_width_ft",
          "type": "number",
          "required": true
        },
        {
          "name": "boat_type",
          "type": "string",
          "required": true,
          "description": "Boat type, e.g., 'open_motorboat', 'pontoon', 'sailboat', 'personal_watercraft', 'other'"
        },
        {
          "name": "water_type",
          "type": "string",
          "required": true,
          "description": "Water type, e.g., 'inland_lake_river', 'coastal', 'offshore_ocean', 'other'"
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "calculated_max_passengers": {
            "type": "number"
          },
          "calculation_method": {
            "type": "string",
