    {
      "name": "searchArticles",
      "description": "Search articles across the site with optional filters and sorting, used by the header search bar and Search Results page.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": true
        },
        {
          "name": "filters",
          "type": "object",
          "required": false,
          "properties": {
            "category": {
              "type": "string",
              "description": "Optional category filter, e.g., 'safety_basics', 'how_to_guides', 'other'"
            },
            "boat_size_category": {
              "type": "string",
              "description": "Optional boat size filter, e.g., 'up_to_26_ft', 'between_26_40_ft', 'over_40_ft', 'all_sizes'"
            },
            "published_from": {
              "type": "string",
              "description": "Optional ISO-8601 date string for earliest publish date (inclusive), e.g., '2022-01-01'"
            },
            "published_to": {
              "type": "string",
              "description": "Optional ISO-8601 date string for latest publish date (inclusive)"
            },
            "min_rating": {
              "type": "number",
              "description": "Minimum rating filter, e.g., 4.0"
            }
          }
        },
        {
          "name": "sort",
          "type": "string",
          "required": false,
          "description": "Sort order, e.g., 'newest_first', 'highest_rated', 'shortest_read_time'"
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "page_size",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "total_results": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "page_size": {
            "type": "number"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "article": {
                  "type": "Article"
                },
                "matched_snippet": {
                  "type": "string",
                  "description": "Short text snippet showing the match context"
                }
              }
            }
          }
        }
      },
      "relatedTasks": [
        "task_4"
      ]
    },
