{
  "entities": [
    {
      "name": "Program",
      "storage_key": "programs",
      "description": "HYIP program listing with core metrics used for filters, rankings, and details.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "slug",
          "type": "string",
          "required": false,
          "description": "URL-friendly identifier"
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "values": [
            "paying",
            "waiting",
            "not_paying",
            "scam",
            "closed",
            "unknown"
          ]
        },
        {
          "name": "is_problematic",
          "type": "boolean",
          "required": true,
          "description": "True if status is scam or not_paying"
        },
        {
          "name": "payment_methods",
          "type": "array",
          "required": true,
          "description": "Array of payment method enums such as bitcoin, usdt"
        },
        {
          "name": "base_currency",
          "type": "enum",
          "required": true,
          "values": [
            "usd",
            "btc",
            "usdt",
            "eur",
            "gbp",
            "other"
          ]
        },
        {
          "name": "min_deposit_base",
          "type": "number",
          "required": true,
          "description": "Minimum deposit in base_currency"
        },
        {
          "name": "min_deposit_usd",
          "type": "number",
          "required": true,
          "description": "Minimum deposit normalized to USD for filtering"
        },
        {
          "name": "daily_roi_percent",
          "type": "number",
          "required": true,
          "description": "Typical advertised daily ROI percent (e.g., 3.0 for 3%)"
        },
        {
          "name": "total_return_30d_percent",
          "type": "number",
          "required": false,
          "description": "Computed 30-day total return percentage used for comparisons"
        },
        {
          "name": "running_days",
          "type": "number",
          "required": true,
          "description": "Number of days the program has been running"
        },
        {
          "name": "start_date",
          "type": "datetime",
          "required": true,
          "description": "Program launch date"
        },
        {
          "name": "end_date",
          "type": "datetime",
          "required": false,
          "description": "End or closure date if closed"
        },
        {
          "name": "payout_rating_value",
          "type": "number",
          "required": false,
          "description": "Aggregate payout rating (e.g., 0–5 where 5 represents 5/5)"
        },
        {
          "name": "risk_level",
          "type": "enum",
          "required": false,
          "values": [
            "very_low",
            "low",
            "medium",
            "high",
            "scam"
          ]
        },
        {
          "name": "comment_count",
          "type": "number",
          "required": false,
          "description": "Number of discussion comments/reviews"
        },
        {
          "name": "has_active_poll",
          "type": "boolean",
          "required": false,
          "description": "Whether this program has a community poll"
        },
        {
          "name": "is_featured",
          "type": "boolean",
          "required": false
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
