{
  "interfaces": [
    {
      "name": "getMarketingPageContent",
      "description": "Fetch structured marketing content for high-level pages like home, product_features, about, contact, privacy_policy, terms_of_service, and help_center.",
      "parameters": [
        {
          "name": "pageKey",
          "type": "string",
          "required": true,
          "description": "Identifier of the marketing page to load, e.g., 'home', 'product_features', 'about', 'contact', 'help_center', 'privacy_policy', 'terms_of_service'."
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "heading": {
                  "type": "string"
                },
                "body": {
                  "type": "string"
                },
                "bullets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "highlight": {
                  "type": "boolean"
                }
              }
            }
          },
          "primary_cta": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "target_page_key": {
                "type": "string",
                "description": "Page key to navigate to when CTA is clicked, e.g., 'pricing', 'plan_signup', 'contact'."
              }
            }
          },
          "secondary_cta": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "target_page_key": {
                "type": "string"
              }
            }
          }
        }
      },
      "relatedTasks": []
    },
    {
      "name": "getPricingPlansForDisplay",
      "description": "Retrieve all active pricing plans with display-friendly fields for the Pricing page, including prices, chatbot limits, and analytics availability.",
      "parameters": [
        {
          "name": "billingPeriod",
          "type": "enum",
          "required": false,
          "values": [
            "monthly",
            "yearly"
          ],
          "description": "Optional: filter plans by billing period. Defaults to 'monthly' if omitted."
        },
        {
          "name": "filters",
          "type": "object",
          "required": false,
          "properties": {
            "maxMonthlyPrice": {
              "type": "number",
              "description": "Optional: maximum monthly price to include, e.g., 40."
            },
            "minChatbots": {
              "type": "number",
              "description": "Optional: minimum number of chatbots supported by the plan."
            },
            "requiresAnalytics": {
              "type": "boolean",
              "description": "Optional: if true, only return plans that include conversation analytics."
            }
          }
        }
      ],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "code": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "monthly_price": {
              "type": "number"
            },
            "billing_period": {
              "type": "string"
            },
            "max_chatbots": {
              "type": "number"
            },
            "includes_conversation_analytics": {
              "type": "boolean"
            },
            "feature_list": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "status": {
              "type": "string"
            },
            "is_most_popular": {
              "type": "boolean"
            },
            "price_display": {
              "type": "string",
              "description": "Human-readable price label, e.g., '$29/mo'."
            },
            "chatbot_limit_display": {
              "type": "string",
              "description": "Human-readable chatbot limit, e.g., 'Up to 5 chatbots'."
            },
            "analytics_display": {
              "type": "string",
              "description": "Human-readable analytics summary, e.g., 'Includes conversation analytics'."
            },
            "highlight_labels": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "relatedTasks": [
        "task_1"
      ]
    },
