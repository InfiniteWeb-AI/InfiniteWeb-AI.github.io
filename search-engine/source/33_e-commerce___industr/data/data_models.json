{
  "entities": [
    {
      "name": "Category",
      "storage_key": "categories",
      "description": "Top-level product categories used for navigation, filtering, and URL parameters",
      "data_pre_generation_num": "few",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "key",
          "type": "enum",
          "required": true,
          "values": [
            "cartridge_filters",
            "dosing_pumps",
            "filter_housings",
            "water_softeners",
            "instrumentation",
            "salts_regenerants",
            "chemicals"
          ],
          "description": "Matches categoryId in URLs (e.g., category.html?categoryId=cartridge_filters)"
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "display_order",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "name": "Product",
      "storage_key": "products",
      "description": "Product available for purchase (filters, pumps, membranes, salts, chemicals, instruments, systems, housings)",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "category_key",
          "type": "enum",
          "required": true,
          "values": [
            "cartridge_filters",
            "dosing_pumps",
            "filter_housings",
            "water_softeners",
            "instrumentation",
            "salts_regenerants",
            "chemicals"
          ],
          "description": "Category this product belongs to"
        },
        {
          "name": "sku",
          "type": "string",
          "required": false
        },
        {
          "name": "price",
          "type": "number",
          "required": true
        },
        {
          "name": "currency",
          "type": "string",
          "required": false
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "values": [
            "active",
            "draft",
            "archived"
          ]
        },
        {
          "name": "rating",
          "type": "number",
          "required": false,
          "description": "Average star rating, e.g., 4.5"
        },
        {
          "name": "rating_count",
          "type": "number",
          "required": false
        },
        {
          "name": "free_shipping",
          "type": "boolean",
          "required": false,
          "description": "True if product qualifies for free shipping filter"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "image_url",
          "type": "string",
          "required": false
        },
        {
          "name": "tags",
          "type": "array",
          "required": false,
          "description": "Free-form product tags/keywords"
        },
        {
          "name": "length_inch",
          "type": "number",
          "required": false,
          "description": "Cartridge or housing length in inches, e.g., 10 or 20"
        },
        {
          "name": "micron_rating",
          "type": "number",
          "required": false,
          "description": "Nominal micron rating, e.g., 1, 5"
        },
        {
          "name": "media_type",
          "type": "enum",
          "required": false,
          "values": [
            "sediment",
            "carbon_block",
            "activated_carbon",
            "polishing",
            "other"
          ],
          "description": "Filter media / type used in cartridge filter tasks"
        },
        {
          "name": "material",
          "type": "enum",
          "required": false,
          "values": [
            "stainless_steel",
            "plastic",
            "carbon_steel",
            "other"
          ],
          "description": "Material for housings and other hardware (e.g., stainless_steel)"
        },
        {
          "name": "pump_type",
          "type": "enum",
          "required": false,
          "values": [
            "digital",
            "mechanical",
            "other"
          ],
          "description": "Pump type used for filtering digital dosing pumps"
        },
        {
          "name": "flow_rate_m3h",
          "type": "number",
          "required": false,
          "description": "Flow rate or capacity in m³/h (for pumps and water softeners)"
        },
        {
          "name": "volume_l",
          "type": "number",
          "required": false,
          "description": "Container or system liquid volume in liters (e.g., 20 L anti-scalant)"
        },
        {
          "name": "package_weight_kg",
          "type": "number",
          "required": false,
          "description": "Package weight in kg (e.g., 25 kg salt bags)"
        },
        {
          "name": "salt_rejection_percent",
          "type": "number",
          "required": false,
          "description": "RO membrane salt rejection percentage (e.g., ≥98%)"
        },
        {
          "name": "membrane_model",
          "type": "string",
          "required": false,
          "description": "Membrane model/size identifier such as '4040'"
        },
        {
          "name": "instrument_type",
          "type": "enum",
          "required": false,
          "values": [
            "conductivity_meter",
            "ph_meter",
            "other"
          ],
          "description": "Instrumentation type; conductivity meters are used in comparison tasks"
        },
        {
          "name": "measurement_range_min",
          "type": "number",
          "required": false,
          "description": "Minimum measurement value for instruments"
        },
        {
          "name": "measurement_range_max",
          "type": "number",
          "required": false,
          "description": "Maximum measurement value for instruments"
        },
        {
          "name": "max_conductivity",
          "type": "number",
          "required": false,
          "description": "Explicit maximum conductivity value if distinct from measurement_range_max"
        },
        {
          "name": "measurement_unit",
          "type": "enum",
          "required": false,
          "values": [
            "us_cm",
            "ms_cm",
            "ppm",
            "other"
          ],
          "description": "Unit for instrument measurement range"
        },
        {
          "name": "shipping_lead_time_days",
          "type": "number",
          "required": false
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "Cart",
      "storage_key": "cart",
      "description": "Shopping cart (single cart for the agent, containing current items)",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "item_ids",
          "type": "array",
          "required": true,
          "description": "Array of CartItem IDs currently in the cart"
        },
        {
          "name": "subtotal",
          "type": "number",
          "required": false,
          "description": "Sum of line totals before shipping/tax"
        },
        {
          "name": "currency",
          "type": "string",
          "required": false
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "CartItem",
      "storage_key": "cart_items",
      "description": "Line item inside the cart for a specific product and quantity",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "cart_id",
          "type": "string",
          "required": true,
          "description": "ID of the Cart this item belongs to"
        },
        {
          "name": "product_id",
          "type": "string",
          "required": true,
          "description": "ID of the Product in this line item"
        },
        {
          "name": "product_name",
          "type": "string",
          "required": true,
          "description": "Snapshot of product name for display"
        },
        {
          "name": "unit_price",
          "type": "number",
          "required": true,
          "description": "Price per unit at time of adding to cart"
        },
        {
          "name": "quantity",
          "type": "number",
          "required": true
        },
        {
          "name": "line_total",
          "type": "number",
          "required": true,
          "description": "unit_price * quantity"
        },
        {
          "name": "free_shipping",
          "type": "boolean",
          "required": false,
          "description": "Snapshot of product free_shipping flag"
        },
        {
          "name": "attributes",
          "type": "array",
          "required": false,
          "description": "Optional array of key attribute strings for display (e.g., '10 inch', '5 µm', 'stainless steel')"
        },
        {
          "name": "added_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "ComparisonList",
      "storage_key": "comparison_lists",
      "description": "List of products selected for side-by-side comparison (e.g., conductivity meters)",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": false
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "ComparisonItem",
      "storage_key": "comparison_items",
      "description": "Product entry in a comparison list for building the comparison table",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "comparison_list_id",
          "type": "string",
          "required": true,
          "description": "ID of ComparisonList this item belongs to"
        },
        {
          "name": "product_id",
          "type": "string",
          "required": true,
          "description": "ID of Product being compared"
        },
        {
          "name": "position",
          "type": "number",
          "required": false,
          "description": "Column order in comparison table"
        },
        {
          "name": "added_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "ShippingMethod",
      "storage_key": "shipping_methods",
      "description": "Available shipping methods that can be selected during checkout",
      "data_pre_generation_num": "few",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "key",
          "type": "enum",
          "required": true,
          "values": [
            "standard",
            "express",
            "pickup"
          ],
          "description": "Internal identifier for method"
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Display name (e.g., 'Standard Shipping')"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "base_cost",
          "type": "number",
          "required": true,
          "description": "Base shipping cost for this method"
        },
        {
          "name": "is_free_option",
          "type": "boolean",
          "required": false,
          "description": "True if this method can be free under some conditions"
        },
        {
          "name": "estimated_days_min",
          "type": "number",
          "required": false
        },
        {
          "name": "estimated_days_max",
          "type": "number",
          "required": false
        },
        {
          "name": "display_order",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "name": "Order",
      "storage_key": "orders",
      "description": "Placed order created from the cart at checkout",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "order_number",
          "type": "string",
          "required": true
        },
        {
          "name": "item_ids",
          "type": "array",
          "required": true,
          "description": "Array of OrderItem IDs included in this order"
        },
        {
          "name": "subtotal",
          "type": "number",
          "required": true
        },
        {
          "name": "shipping_cost",
          "type": "number",
          "required": false
        },
        {
          "name": "total",
          "type": "number",
          "required": true
        },
        {
          "name": "currency",
          "type": "string",
          "required": false
        },
        {
          "name": "shipping_method_id",
          "type": "string",
          "required": false,
          "description": "Chosen ShippingMethod for this order"
        },
        {
          "name": "shipping_name",
          "type": "string",
          "required": false
        },
        {
          "name": "shipping_address_line1",
          "type": "string",
          "required": false
        },
        {
          "name": "shipping_address_line2",
          "type": "string",
          "required": false
        },
        {
          "name": "shipping_city",
          "type": "string",
          "required": false
        },
        {
          "name": "shipping_postal_code",
          "type": "string",
          "required": false
        },
        {
          "name": "shipping_country",
          "type": "string",
          "required": false
        },
        {
          "name": "contact_email",
          "type": "string",
          "required": false
        },
        {
          "name": "contact_phone",
          "type": "string",
          "required": false
        },
        {
          "name": "customer_notes",
          "type": "string",
          "required": false
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "values": [
            "draft",
            "placed",
            "shipped",
            "cancelled"
          ]
        },
        {
          "name": "placed_at",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "OrderItem",
      "storage_key": "order_items",
      "description": "Snapshot of a product line included in an order",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "order_id",
          "type": "string",
          "required": true,
          "description": "ID of Order this item belongs to"
        },
        {
          "name": "product_id",
          "type": "string",
          "required": true,
          "description": "Original Product ID"
        },
        {
          "name": "product_name",
          "type": "string",
          "required": true
        },
        {
          "name": "unit_price",
          "type": "number",
          "required": true
        },
        {
          "name": "quantity",
          "type": "number",
          "required": true
        },
        {
          "name": "line_total",
          "type": "number",
          "required": true
        },
        {
          "name": "attributes",
          "type": "array",
          "required": false,
          "description": "Snapshot of key attributes (e.g., '10 inch', '5 µm', 'digital dosing pump')"
        }
      ]
    }
  ],
  "relationships": [
    {
      "from": "Product",
      "to": "Category",
      "type": "belongs_to",
      "field": "category_key",
      "description": "Each product belongs to one top-level category"
    },
    {
      "from": "Category",
      "to": "Product",
      "type": "has_many",
      "field": "category_key",
      "description": "Categories list many products"
    },
    {
      "from": "CartItem",
      "to": "Product",
      "type": "belongs_to",
      "field": "product_id"
    },
    {
      "from": "CartItem",
      "to": "Cart",
      "type": "belongs_to",
      "field": "cart_id"
    },
    {
      "from": "Cart",
      "to": "CartItem",
      "type": "has_many",
      "field": "item_ids"
    },
    {
      "from": "ComparisonItem",
      "to": "ComparisonList",
      "type": "belongs_to",
      "field": "comparison_list_id"
    },
    {
      "from": "ComparisonItem",
      "to": "Product",
      "type": "belongs_to",
      "field": "product_id"
    },
    {
      "from": "ComparisonList",
      "to": "ComparisonItem",
      "type": "has_many",
      "field": "id"
    },
    {
      "from": "OrderItem",
      "to": "Order",
      "type": "belongs_to",
      "field": "order_id"
    },
    {
      "from": "OrderItem",
      "to": "Product",
      "type": "belongs_to",
      "field": "product_id"
    },
    {
      "from": "Order",
      "to": "OrderItem",
      "type": "has_many",
      "field": "item_ids"
    },
    {
      "from": "Order",
      "to": "ShippingMethod",
      "type": "belongs_to",
      "field": "shipping_method_id"
    }
  ]
}