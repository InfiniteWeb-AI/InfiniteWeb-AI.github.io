    {
      "name": "searchTherapists",
      "description": "Search therapists for the directory based on filters like specialty, format, pricing, rating, and weekend availability.",
      "parameters": [
        {
          "name": "filters",
          "type": "object",
          "required": true,
          "properties": {
            "specialtyFilters": {
              "type": "array",
              "required": false,
              "items": {
                "type": "string",
                "description": "Specialty codes such as 'anxiety', 'trauma_ptsd'"
              }
            },
            "slidingScaleOnly": {
              "type": "boolean",
              "required": false
            },
            "maxFee": {
              "type": "number",
              "required": false
            },
            "formatFilters": {
              "type": "array",
              "required": false,
              "items": {
                "type": "string",
                "description": "Session formats such as 'in_person', 'online'"
              }
            },
            "zipCode": {
              "type": "string",
              "required": false
            },
            "ratingMin": {
              "type": "number",
              "required": false
            },
            "availabilityDays": {
              "type": "array",
              "required": false,
              "items": {
                "type": "string",
                "description": "Day of week codes such as 'saturday', 'sunday'"
              }
            }
          }
        },
        {
          "name": "sortBy",
          "type": "string",
          "required": false,
          "description": "Sort order. Allowed values: 'next_available', 'price_low_to_high', 'rating_high_to_low'"
        },
        {
          "name": "limit",
          "type": "number",
          "required": false,
          "default": 20
        },
        {
          "name": "offset",
          "type": "number",
          "required": false,
          "default": 0
        }
      ],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "therapist": {
              "type": "Therapist"
            },
            "nextAvailableSlotSummary": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "description": "ISO 8601 date of next available slot, if any"
                },
                "time": {
                  "type": "string",
                  "description": "Local start time, e.g., '17:30'"
                },
                "isWeekend": {
                  "type": "boolean"
                },
                "isEvening": {
                  "type": "boolean"
                }
              }
            },
            "minFee": {
              "type": "number"
            },
            "maxFee": {
              "type": "number"
            },
            "offersSlidingScale": {
              "type": "boolean"
            },
            "averageRating": {
              "type": "number"
            },
            "ratingCount": {
              "type": "number"
            }
          }
        }
      },
