        {
          "name": "venue_style_tags",
          "type": "array",
          "required": false,
          "description": "Array of venue style slugs such as 'barn', 'hotel_ballroom', etc."
        },
        {
          "name": "budget_per_guest_min",
          "type": "number",
          "required": false,
          "description": "Minimum per-guest budget in dollars (e.g., 40)."
        },
        {
          "name": "budget_per_guest_max",
          "type": "number",
          "required": false,
          "description": "Maximum per-guest budget in dollars (e.g., 60)."
        },
        {
          "name": "budget_per_guest_label",
          "type": "string",
          "required": false,
          "description": "Display label for per-guest budget range (e.g., '$40–$60')."
