          "type": "number",
          "required": false,
          "description": "Minimum total wedding budget this article is aimed at."
        },
        {
          "name": "overall_budget_max",
          "type": "number",
          "required": false,
          "description": "Maximum total wedding budget this article is aimed at (e.g., 10000 for 'Under $10,000')."
        },
        {
          "name": "overall_budget_label",
