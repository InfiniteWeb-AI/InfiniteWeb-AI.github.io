        {
          "name": "guest_count_min",
          "type": "number",
          "required": false,
          "description": "Minimum recommended guest count (e.g., 120)."
        },
        {
          "name": "guest_count_max",
          "type": "number",
          "required": false,
          "description": "Maximum recommended guest count (e.g., 180)."
        },
        {
          "name": "guest_count_label",
          "type": "string",
          "required": false,
          "description": "Display label for guest count range (e.g., 'Around 150 guests (120–180)')."
