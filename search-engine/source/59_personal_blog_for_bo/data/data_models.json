{
  "entities": [
    {
      "name": "Review",
      "storage_key": "reviews",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "name": "slug",
          "type": "string",
          "required": false
        },
        {
          "name": "content_type",
          "type": "enum",
          "required": true,
          "values": [
            "books",
            "movies"
          ],
          "description": "Used in URLs and filters (e.g., content_type=books, content_type=movies)"
        },
        {
          "name": "genre",
          "type": "string",
          "required": false,
          "description": "e.g., Science Fiction, Mystery, Thriller, Comedy"
        },
        {
          "name": "body",
          "type": "string",
          "required": false,
          "description": "Full review text"
        },
        {
          "name": "rating",
          "type": "number",
          "required": true,
          "description": "Overall star rating, supports half-stars like 4.5"
        },
        {
          "name": "ratingCount",
          "type": "number",
          "required": false,
          "description": "Number of individual ratings, if tracked"
        },
        {
          "name": "publishedAt",
          "type": "datetime",
          "required": true,
          "description": "When the review was published (used for 'last 6 months' and homepage newest sorting)"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "authorId",
          "type": "string",
          "required": true,
          "description": "Reviewer/author of this post"
        },
        {
          "name": "publicationYear",
          "type": "number",
          "required": false,
          "description": "For books: publication year filter (e.g., >= 2016)"
        },
        {
          "name": "releaseYear",
          "type": "number",
          "required": false,
          "description": "For movies: release year filter (e.g., >= 2021)"
        },
        {
          "name": "runtimeMinutes",
          "type": "number",
          "required": false,
          "description": "For movies: runtime filter (e.g., > 120)"
        },
        {
          "name": "likeCount",
          "type": "number",
          "required": false
        },
        {
          "name": "commentCount",
          "type": "number",
          "required": false
        },
        {
          "name": "popularityScore",
          "type": "number",
          "required": false,
          "description": "Used for 'Most Popular' sorting"
        },
        {
          "name": "thumbnailUrl",
          "type": "string",
          "required": false
        },
        {
          "name": "tagsSummary",
          "type": "string",
          "required": false,
          "description": "Optional denormalized list of tags for quick display/search (comma-separated)"
        }
      ],
      "data_pre_generation_num": "many",
      "description": "Core content entity representing a single book or movie review used on listings, search, and detail pages."
    },
    {
      "name": "Author",
      "storage_key": "authors",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "bio",
          "type": "string",
          "required": false
        },
        {
          "name": "avatarUrl",
          "type": "string",
          "required": false
        },
        {
          "name": "reviewCount",
          "type": "number",
          "required": false
        },
        {
          "name": "averageRating",
          "type": "number",
          "required": false
        },
        {
          "name": "followersCount",
          "type": "number",
          "required": false
        },
        {
          "name": "isFollowed",
          "type": "boolean",
          "required": false,
          "description": "Whether the single local user is following this author"
        }
      ],
      "data_pre_generation_num": "few",
      "description": "Review authors whose profile pages can be viewed and followed."
    },
    {
      "name": "Comment",
      "storage_key": "comments",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "reviewId",
          "type": "string",
          "required": true
        },
        {
          "name": "authorName",
          "type": "string",
          "required": false,
          "description": "Name shown next to the comment; can be a simple display name for the single user"
        },
        {
          "name": "content",
          "type": "string",
          "required": true
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "isDeleted",
          "type": "boolean",
          "required": false
        }
      ],
      "data_pre_generation_num": "none",
      "description": "User comments posted on review detail pages."
    },
    {
      "name": "ReadingList",
      "storage_key": "reading_lists",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Display name such as 'Favorites', 'Watchlist', 'Save for Later', 'Summer 2026'"
        },
        {
          "name": "listType",
          "type": "enum",
          "required": true,
          "values": [
            "favorites",
            "watchlist",
            "save_for_later",
            "custom"
          ],
          "description": "Determines default behavior and special handling for built-in lists"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "isDefault",
          "type": "boolean",
          "required": false,
          "description": "True for built-in lists like Favorites, Watchlist, Save for Later"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ],
      "data_pre_generation_num": "few",
      "description": "Named collections of reviews such as Favorites, Watchlist, Save for Later, and custom lists like 'Summer 2026'."
    },
    {
      "name": "ReadingListItem",
      "storage_key": "reading_list_items",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "listId",
          "type": "string",
          "required": true
        },
        {
          "name": "reviewId",
          "type": "string",
          "required": true
        },
        {
          "name": "addedAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "notes",
          "type": "string",
          "required": false
        },
        {
          "name": "position",
          "type": "number",
          "required": false,
          "description": "Optional ordering within a list"
        }
      ],
      "data_pre_generation_num": "none",
      "description": "Membership of reviews in specific reading lists or watchlists."
    },
    {
      "name": "ReviewInteraction",
      "storage_key": "review_interactions",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "reviewId",
          "type": "string",
          "required": true
        },
        {
          "name": "isRead",
          "type": "boolean",
          "required": false,
          "description": "For homepage 'Mark as Read' actions"
        },
        {
          "name": "readAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "isSavedForLater",
          "type": "boolean",
          "required": false,
          "description": "Whether this review is currently in the 'Save for Later' list"
        },
        {
          "name": "savedForLaterAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "isLiked",
          "type": "boolean",
          "required": false,
          "description": "Whether the single user has liked this review"
        },
        {
          "name": "likedAt",
          "type": "datetime",
          "required": false
        }
      ],
      "data_pre_generation_num": "none",
      "description": "Per-review interaction state for the single local user (read, saved for later, liked)."
    },
    {
      "name": "Tag",
      "storage_key": "tags",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Human-readable tag label, e.g., 'Lord of the Rings'"
        },
        {
          "name": "slug",
          "type": "string",
          "required": false,
          "description": "Machine-friendly identifier, e.g., 'lord_of_the_rings'"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        }
      ],
      "data_pre_generation_num": "few",
      "description": "Tags applied to reviews and used in search filters (e.g., 'Lord of the Rings')."
    },
    {
      "name": "ReviewTag",
      "storage_key": "review_tags",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "reviewId",
          "type": "string",
          "required": true
        },
        {
          "name": "tagId",
          "type": "string",
          "required": true
        }
      ],
      "data_pre_generation_num": "many",
      "description": "Join table linking reviews and tags for tag-based filtering and search."
    },
    {
      "name": "NewsletterSubscription",
      "storage_key": "newsletter_subscriptions",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "email",
          "type": "string",
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": false
        },
        {
          "name": "mainFrequency",
          "type": "enum",
          "required": true,
          "values": [
            "none",
            "daily",
            "weekly",
            "monthly",
            "custom_per_category"
          ],
          "description": "Overall frequency setting; 'custom_per_category' enables per-category controls."
        },
        {
          "name": "booksFrequency",
          "type": "enum",
          "required": false,
          "values": [
            "none",
            "daily",
            "weekly",
            "monthly"
          ],
          "description": "Effective when mainFrequency is 'custom_per_category'."
        },
        {
          "name": "moviesFrequency",
          "type": "enum",
          "required": false,
          "values": [
            "none",
            "daily",
            "weekly",
            "monthly"
          ],
          "description": "Effective when mainFrequency is 'custom_per_category'."
        },
        {
          "name": "sendOnlyHighRated",
          "type": "boolean",
          "required": false,
          "description": "Checkbox 'Only send reviews rated 4+ stars'"
        },
        {
          "name": "minRating",
          "type": "number",
          "required": false,
          "description": "Minimum rating threshold (e.g., 4) when sendOnlyHighRated is enabled"
        },
        {
          "name": "isActive",
          "type": "boolean",
          "required": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ],
      "data_pre_generation_num": "none",
      "description": "Newsletter subscription record and per-category frequency preferences for the single user."
    },
    {
      "name": "ContactMessage",
      "storage_key": "contact_messages",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "email",
          "type": "string",
          "required": true
        },
        {
          "name": "message",
          "type": "string",
          "required": true
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "values": [
            "new",
            "read",
            "archived"
          ],
          "description": "Internal tracking of message handling state"
        }
      ],
      "data_pre_generation_num": "none",
      "description": "Messages sent via the Contact form, including feedback about specific reviews."
    }
  ],
  "relationships": [
    {
      "from": "Review",
      "to": "Author",
      "type": "belongs_to",
      "field": "authorId"
    },
    {
      "from": "Comment",
      "to": "Review",
      "type": "belongs_to",
      "field": "reviewId"
    },
    {
      "from": "ReadingListItem",
      "to": "ReadingList",
      "type": "belongs_to",
      "field": "listId"
    },
    {
      "from": "ReadingListItem",
      "to": "Review",
      "type": "belongs_to",
      "field": "reviewId"
    },
    {
      "from": "ReviewInteraction",
      "to": "Review",
      "type": "belongs_to",
      "field": "reviewId"
    },
    {
      "from": "ReviewTag",
      "to": "Review",
      "type": "belongs_to",
      "field": "reviewId"
    },
    {
      "from": "ReviewTag",
      "to": "Tag",
      "type": "belongs_to",
      "field": "tagId"
    }
  ]
}