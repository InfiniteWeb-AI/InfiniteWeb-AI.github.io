            "paver_driveway"
          ]
        },
        {
          "name": "driveway_size_sq_ft",
          "type": "number",
          "required": false,
          "description": "Area in square feet (e.g., 600, 550)"
        },
        {
          "name": "size_unit",
          "type": "enum",
          "required": false,
          "values": [
            "square_feet",
            "feet"
          ],
          "description": "Unit for size fields; sq ft for area or ft for length"
        },
        {
          "name": "driveway_length_ft",
          "type": "number",
          "required": false,
          "description": "Used for snow removal (e.g., 50 ft driveway)"
        },
        {
          "name": "driveway_category",
          "type": "enum",
          "required": false,
          "values": [
            "single_car",
            "two_car",
            "three_car",
            "other"
          ],
          "description": "Categorical size, e.g. 2-car driveway"
        },
        {
          "name": "material_option",
          "type": "enum",
          "required": false,
          "values": [
            "standard",
            "premium",
            "economy"
          ],
          "description": "If a material/finish is chosen as part of booking"
        },
        {
          "name": "scheduled_date",
          "type": "datetime",
          "required": false,
          "description": "Selected service date (weekday/Saturday, etc.)"
        },
        {
          "name": "time_slot_start",
          "type": "string",
          "required": false,
          "description": "Start time of the selected time slot, e.g. '09:00'"
        },
        {
          "name": "time_slot_end",
          "type": "string",
          "required": false,
          "description": "End time of the selected time slot, e.g. '11:00'"
        },
        {
          "name": "payment_method",
          "type": "enum",
          "required": false,
          "values": [
            "credit_debit_card",
            "cash_on_site",
            "bank_transfer",
            "online_wallet"
          ]
        },
        {
          "name": "billing_option",
          "type": "enum",
          "required": false,
          "values": [
            "per_season",
            "per_visit",
            "monthly",
            "one_time"
          ],
          "description": "Used for snow removal billing options"
        },
        {
          "name": "contact_name",
          "type": "string",
          "required": true
        },
        {
          "name": "contact_phone",
          "type": "string",
          "required": true
        },
        {
          "name": "contact_email",
          "type": "string",
          "required": true
        },
        {
          "name": "applied_promo_code",
          "type": "string",
          "required": false,
          "description": "Promo code entered on booking_review.html"
        },
        {
          "name": "promo_discount_percent",
          "type": "number",
          "required": false
        },
        {
          "name": "subtotal_price",
          "type": "number",
          "required": false,
          "description": "Price before discounts"
        },
        {
          "name": "discount_amount",
          "type": "number",
          "required": false
        },
        {
          "name": "total_price",
          "type": "number",
          "required": false,
          "description": "Final price after promotions"
