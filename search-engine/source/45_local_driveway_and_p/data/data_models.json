{
  "entities": [
    {
      "name": "Service",
      "storage_key": "services",
      "description": "Top-level driveway/paving service categories shown on service.html and used throughout the site",
      "data_pre_generation_num": "few",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true,
          "description": "Matches serviceId in URLs, e.g. concrete_driveways, driveway_sealing"
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Display name, e.g. 'Concrete Driveways'"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "service_type",
          "type": "enum",
          "required": true,
          "values": [
            "asphalt_resurfacing",
            "asphalt_driveway_replacement",
            "concrete_driveways",
            "driveway_sealing",
            "snow_removal",
            "general_driveway_paving",
            "asphalt_driveway",
            "paver_driveway"
          ],
          "description": "Canonical service type used by packages, promos, crews, etc."
        },
        {
          "name": "category",
          "type": "enum",
          "required": true,
          "values": [
            "installation",
            "maintenance",
            "seasonal",
            "repair",
            "resurfacing",
            "replacement"
          ],
          "description": "High-level category for grouping services"
        },
        {
          "name": "default_warranty_years",
          "type": "number",
          "required": false
        },
        {
          "name": "is_active",
          "type": "boolean",
          "required": true,
          "description": "Whether this service is currently offered"
        },
        {
          "name": "sort_order",
          "type": "number",
          "required": false,
          "description": "Controls display ordering in service lists"
        }
      ]
    },
    {
      "name": "ServicePackage",
      "storage_key": "service_packages",
      "description": "Concrete packages/plans/pricing options under each service (installation packages, sealing plans, seasonal snow removal plans, etc.)",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "service_id",
          "type": "string",
          "required": true,
          "description": "References Service.id"
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Package/plan name shown on service.html"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "package_type",
          "type": "enum",
          "required": true,
          "values": [
            "installation_package",
            "sealing_plan",
            "seasonal_plan",
            "resurfacing_package",
            "replacement_package",
            "general_service_package"
          ]
        },
        {
          "name": "base_price",
          "type": "number",
          "required": true,
          "description": "Total or starting price in dollars"
        },
        {
          "name": "warranty_years",
          "type": "number",
          "required": false,
          "description": "Warranty duration in years, used for filtering 2-year, 3-year+"
        },
        {
          "name": "recommended_min_size_sq_ft",
          "type": "number",
          "required": false,
          "description": "Minimum driveway size this package is suited for"
        },
        {
          "name": "recommended_max_size_sq_ft",
          "type": "number",
          "required": false,
          "description": "Maximum driveway size this package is suited for"
        },
        {
          "name": "supported_driveway_categories",
          "type": "array",
          "required": false,
          "description": "Array of driveway_category values this package supports (e.g., includes two_car for 2-car driveways)"
        },
        {
          "name": "supported_surface_types",
          "type": "array",
          "required": false,
          "description": "Array of driveway surface types, e.g. ['asphalt', 'concrete']"
        },
        {
          "name": "includes_crack_filling",
          "type": "boolean",
          "required": false,
          "description": "True if plan explicitly includes crack filling (for sealing plans)"
        },
        {
          "name": "max_visits",
          "type": "number",
          "required": false,
          "description": "For seasonal plans like snow removal; used for 'up to 20 visits'"
        },
        {
          "name": "max_driveway_length_ft",
          "type": "number",
          "required": false,
          "description": "Max driveway length covered by the plan"
        },
        {
          "name": "is_active",
          "type": "boolean",
          "required": true
        },
        {
          "name": "display_order",
          "type": "number",
          "required": false
        }
      ]
    },
    {
