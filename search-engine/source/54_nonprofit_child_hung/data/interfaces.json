    {
      "name": "submitDonation",
      "description": "Submit a one-time or monthly donation, including payment details, and return confirmation information.",
      "parameters": [
        {
          "name": "donationType",
          "type": "string",
          "required": true,
          "description": "Type of donation; e.g., 'general_donation', 'program_restricted', 'country_targeted'."
        },
        {
          "name": "frequency",
          "type": "string",
          "required": true,
          "description": "Donation frequency; 'one_time' or 'monthly'."
        },
        {
          "name": "amount",
          "type": "number",
          "required": true
        },
        {
          "name": "currency",
          "type": "string",
          "required": true,
          "description": "ISO currency code, e.g., 'USD'."
        },
        {
          "name": "programId",
          "type": "string",
          "required": false,
          "description": "Program to support for program-restricted donations (context from Donate or Program pages)."
        },
        {
          "name": "countryId",
          "type": "string",
          "required": false,
          "description": "Country to support for country-targeted donations (selected in monthly donation flow)."
        },
        {
          "name": "coverProcessingFees",
          "type": "boolean",
          "required": true
        },
        {
          "name": "chargeDayOfMonth",
          "type": "number",
          "required": false,
          "description": "For monthly gifts, the day of the month to charge (e.g., 15)."
        },
        {
          "name": "smsOptIn",
          "type": "boolean",
          "required": false,
          "description": "Whether donor opts into SMS updates (monthly gifts)."
        },
        {
          "name": "smsPhoneNumber",
          "type": "string",
          "required": false
        },
        {
          "name": "paymentMethodType",
          "type": "string",
          "required": true,
          "description": "Payment method; e.g., 'credit_debit_card'."
        },
        {
          "name": "cardholderName",
          "type": "string",
          "required": true
        },
        {
          "name": "cardNumber",
          "type": "string",
          "required": true,
          "description": "Full card number; will be tokenized and not stored in full."
        },
        {
          "name": "cardExpMonth",
          "type": "number",
          "required": true
        },
        {
          "name": "cardExpYear",
          "type": "number",
          "required": true
        },
        {
          "name": "cardCvv",
          "type": "string",
          "required": true
        },
        {
          "name": "billingAddressLine1",
          "type": "string",
          "required": true
        },
        {
          "name": "billingAddressLine2",
          "type": "string",
          "required": false
        },
        {
          "name": "billingCity",
          "type": "string",
          "required": true
        },
        {
          "name": "billingState",
          "type": "string",
          "required": true
        },
        {
          "name": "billingPostalCode",
          "type": "string",
          "required": true
        },
        {
          "name": "billingCountry",
          "type": "string",
          "required": true
        },
        {
          "name": "donorFullName",
          "type": "string",
          "required": true
        },
        {
          "name": "donorEmail",
          "type": "string",
          "required": true
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "donation": {
            "type": "Donation"
          },
          "recurringSchedule": {
            "type": "RecurringDonationSchedule",
            "description": "Present for monthly gifts; null for one-time."
          },
          "message": {
            "type": "string"
          },
          "supportSummary": {
            "type": "string",
            "description": "Human-readable summary of what the gift supports."
          }
        }
      },
