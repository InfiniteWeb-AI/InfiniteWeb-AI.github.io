        {
          "name": "is_active",
          "type": "boolean",
          "required": true
        },
        {
          "name": "rating",
          "type": "number",
          "required": false,
          "description": "Average rating 0–5 if used"
        },
        {
          "name": "display_order",
          "type": "number",
          "required": false
        }
      ]
    },
    {
