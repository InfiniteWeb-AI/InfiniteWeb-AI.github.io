            "legs",
            "arms",
            "face",
            "brows",
            "face_brows",
            "bikini_brazilian",
            "body",
            "men"
          ],
          "description": "High-level category used for filtering (legs, face/brows, men, etc.)"
        },
        {
          "name": "area_key",
          "type": "string",
          "required": true,
          "description": "Sub-area or specific service key, e.g., 'full_leg', 'half_leg', 'brazilian', 'underarm', 'chest', 'back', 'eyebrow', 'upper_lip', 'chin', 'full_back'"
        },
        {
          "name": "gender_segment",
          "type": "enum",
          "required": false,
          "values": [
            "unisex",
            "women",
            "men"
          ],
          "description": "Intended audience if differentiated"
        },
        {
          "name": "duration_minutes",
          "type": "number",
          "required": true,
          "description": "Standard duration in minutes"
        },
        {
          "name": "base_price",
          "type": "number",
          "required": true
