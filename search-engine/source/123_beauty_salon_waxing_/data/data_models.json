      "description": "Individual waxing service (e.g., Full Leg, Brazilian, Eyebrow) that can be booked alone or combined into sessions and packages.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Display name, e.g., 'Full Leg Wax'"
