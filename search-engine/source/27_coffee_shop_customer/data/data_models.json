          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "sortOrder",
          "type": "number",
          "required": true
        }
      ]
    },
    {
      "name": "Product",
      "storage_key": "products",
      "description": "Menu products (drinks and food) that can be ordered and appear in order history.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "description",
