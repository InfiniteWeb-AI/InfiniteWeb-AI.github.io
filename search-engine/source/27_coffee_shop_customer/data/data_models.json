          "required": true
        },
        {
          "name": "pushPromotionsEnabled",
          "type": "boolean",
          "required": true
        },
        {
          "name": "pushOrderUpdatesEnabled",
          "type": "boolean",
          "required": true
        },
        {
          "name": "smsOrderUpdatesEnabled",
          "type": "boolean",
          "required": true
        },
        {
          "name": "smsPromotionsEnabled",
          "type": "boolean",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": true
        }
      ]
    },
    {
      "name": "Store",
      "storage_key": "stores",
      "description": "Coffee shop locations that can be searched, viewed, and used for pickup orders.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "addressLine1",
          "type": "string",
          "required": true
        },
        {
          "name": "addressLine2",
          "type": "string",
          "required": false
        },
        {
          "name": "city",
          "type": "string",
          "required": true
        },
        {
          "name": "state",
          "type": "string",
          "required": true
        },
        {
          "name": "zipCode",
          "type": "string",
          "required": true
        },
        {
          "name": "latitude",
          "type": "number",
