        {
          "name": "termsAccepted",
          "type": "boolean",
          "required": true
        },
        {
          "name": "passwordLastChangedAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": true
        }
      ]
    },
    {
      "name": "NotificationPreferences",
      "storage_key": "notification_preferences",
      "description": "Granular notification settings for email, push, and SMS channels.",
