{
  "entities": [
    {
      "name": "AccountProfile",
      "storage_key": "account_profiles",
      "description": "Single local customer account profile for this agent, including login credentials, preferences, and loyalty summary.",
      "data_pre_generation_num": "few",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "fullName",
          "type": "string",
          "required": true
        },
        {
          "name": "email",
          "type": "string",
          "required": true
        },
        {
          "name": "password",
          "type": "string",
          "required": true,
          "description": "Stored password or test password value used for login flows"
        },
        {
          "name": "favoriteStoreId",
          "type": "string",
          "required": false,
          "description": "ID of the Store set as favorite"
        },
        {
          "name": "defaultPaymentCardId",
          "type": "string",
          "required": false,
          "description": "ID of the PaymentCard marked as default"
        },
        {
          "name": "loyaltyPointsBalance",
          "type": "number",
          "required": true,
          "description": "Current available loyalty points"
        },
        {
          "name": "loyaltyTier",
          "type": "enum",
          "required": true,
          "values": [
            "none",
            "bronze",
            "silver",
            "gold",
            "platinum"
          ]
