    {
      "name": "searchHelpArticles",
      "description": "Search help articles by query with optional category filters and sort order for the global search bar and search results page.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": true,
          "description": "Full-text search query, e.g., 'shipping policy template' or 'sync_409 product feed error'."
        },
        {
          "name": "filters",
          "type": "object",
          "required": false,
          "properties": {
            "categoryIds": {
              "type": "array",
              "items": {
                "type": "string",
                "entityReference": {
                  "entity": "HelpCategory",
                  "displayField": "name",
                  "valueField": "id"
                }
              },
              "description": "Limit results to these help categories."
            }
          }
        },
        {
          "name": "sort",
          "type": "string",
          "required": false,
          "default": "most_relevant",
          "description": "Sort mode: 'most_relevant', 'most_popular', or 'most_recent'."
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "pageSize",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "total_results": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "page_size": {
            "type": "number"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "HelpArticle.id"
                },
                "title": {
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "category_id": {
                  "type": "string"
                },
                "category_name": {
                  "type": "string"
                },
                "article_type": {
                  "type": "string"
                },
                "integration_platform": {
                  "type": "string"
                },
                "popularity_score": {
                  "type": "number"
                },
                "has_share_link": {
                  "type": "boolean"
                },
                "has_video_tutorial": {
                  "type": "boolean"
                },
                "primary_video_duration_seconds": {
                  "type": "number",
                  "description": "Duration of primary video if present, from ArticleVideo.duration_seconds."
                }
              }
            }
          },
          "available_category_filters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "HelpCategory.id"
                },
                "name": {
                  "type": "string"
                },
                "article_count": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
