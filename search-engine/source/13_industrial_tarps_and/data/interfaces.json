    {
      "name": "searchProducts",
      "description": "Search and browse products by query, category, filters, and sort order. Used by global search and category listing pages.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": false,
          "description": "Free-text search query from the global search bar, e.g., '20x30 heavy duty waterproof tarp'."
        },
        {
          "name": "categoryId",
          "type": "string",
          "required": false,
          "description": "Optional category filter, e.g., 'fire_retardant_tarps' or 'pallet_covers'.",
          "entityReference": {
            "entity": "Category",
            "displayField": "display_name",
            "valueField": "id"
          }
        },
        {
          "name": "productType",
          "type": "string",
          "required": false,
          "description": "Optional product_type filter, e.g., 'tarp', 'generator_cover', 'pallet_cover'."
        },
        {
          "name": "filters",
          "type": "object",
          "required": false,
          "properties": {
            "minPrice": {
              "type": "number",
              "description": "Minimum product price filter."
            },
            "maxPrice": {
              "type": "number",
              "description": "Maximum product price filter."
            },
            "minRating": {
              "type": "number",
              "description": "Minimum average_rating filter, e.g., 4.0 or 4.5."
            },
            "sizeLabel": {
              "type": "string",
              "description": "Exact size label filter, e.g., '20 ft x 30 ft'."
            },
            "widthFt": {
              "type": "number",
              "description": "Optional width filter in feet for tarps."
            },
            "lengthFt": {
              "type": "number",
              "description": "Optional length filter in feet for tarps."
            },
            "featureHeavyDuty": {
              "type": "boolean",
              "description": "Filter for feature_heavy_duty = true."
            },
            "featureWaterproof": {
              "type": "boolean",
              "description": "Filter for feature_waterproof = true."
            },
            "featureFireRetardant": {
              "type": "boolean",
              "description": "Filter for feature_fire_retardant = true."
            },
            "featureUvResistant": {
              "type": "boolean",
              "description": "Filter for feature_uv_resistant = true."
            },
            "usageEnvironment": {
              "type": "string",
              "description": "Usage environment filter, e.g., 'indoor', 'outdoor', 'indoor_outdoor'."
            },
            "hasFreeShipping": {
              "type": "boolean",
              "description": "Filter for has_free_shipping = true."
            },
            "minInteriorLengthIn": {
              "type": "number",
              "description": "Minimum interior length capacity in inches (for covers)."
            },
            "minInteriorWidthIn": {
              "type": "number",
              "description": "Minimum interior width capacity in inches (for covers)."
            },
            "minInteriorHeightIn": {
              "type": "number",
              "description": "Minimum interior height capacity in inches (for covers)."
            },
            "palletLengthIn": {
              "type": "number",
              "description": "Exact pallet length in inches (for pallet covers), e.g., 48."
            },
            "palletWidthIn": {
              "type": "number",
              "description": "Exact pallet width in inches (for pallet covers), e.g., 40."
            },
            "packQuantities": {
              "type": "array",
              "items": {
                "type": "number"
              },
              "description": "Allowed pack_quantity values, e.g., [25, 50] for pallet cover packs."
            }
          }
        },
        {
          "name": "sort",
          "type": "string",
          "required": false,
          "description": "Sort order, e.g., 'relevance', 'price_low_to_high', 'price_high_to_low', 'rating_high_to_low'."
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "pageSize",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "products": {
            "type": "array",
            "items": "Product"
          },
          "total_results": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "page_size": {
            "type": "number"
          },
          "applied_sort": {
            "type": "string"
          },
          "available_sorts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "relatedTasks": [
        "task_1",
        "task_2",
        "task_3",
        "task_4",
        "task_5",
        "task_6"
      ]
    },
    {
      "name": "getCatalogFilterOptions",
      "description": "Get available filter options (sizes, features, price range, ratings, shipping, pallet sizes, pack sizes) for a given catalog context.",
      "parameters": [
        {
          "name": "context",
          "type": "object",
          "required": false,
          "properties": {
            "categoryId": {
              "type": "string",
              "description": "Optional category scope for filter options, e.g., 'fire_retardant_tarps'.",
              "entityReference": {
                "entity": "Category",
                "displayField": "display_name",
                "valueField": "id"
              }
            },
            "productType": {
              "type": "string",
              "description": "Optional product_type scope, e.g., 'tarp', 'generator_cover', 'pallet_cover'."
            }
          }
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "price": {
            "type": "object",
            "properties": {
              "min_price": {
                "type": "number"
              },
              "max_price": {
                "type": "number"
              }
            }
          },
          "size_options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "size_label": {
                  "type": "string"
                },
                "width_ft": {
                  "type": "number"
                },
                "length_ft": {
                  "type": "number"
                }
              }
            }
          },
          "rating_thresholds": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "number",
                  "description": "Rating cutoff, e.g., 4.0, 4.5."
                },
                "label": {
                  "type": "string",
                  "description": "User-facing label, e.g., '4 stars & up'."
                }
              }
            }
          },
          "feature_options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string",
                  "description": "Feature key, e.g., 'heavy_duty', 'waterproof', 'fire_retardant', 'uv_resistant'."
                },
                "label": {
                  "type": "string"
                }
              }
            }
          },
          "shipping_options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string",
                  "description": "Shipping option key, e.g., 'free_shipping'."
                },
                "label": {
                  "type": "string"
                }
              }
            }
          },
          "usage_environments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string",
                  "description": "Usage environment value, e.g., 'indoor', 'outdoor', 'indoor_outdoor'."
                },
                "label": {
                  "type": "string"
                }
              }
            }
          },
          "pallet_sizes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "pallet_length_in": {
                  "type": "number"
                },
                "pallet_width_in": {
                  "type": "number"
                },
                "label": {
                  "type": "string",
                  "description": "User-facing label, e.g., '48 in x 40 in'."
                }
              }
            }
          },
          "pack_quantities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "quantity": {
                  "type": "number"
                },
                "label": {
                  "type": "string",
                  "description": "Label such as 'Pack of 25'."
                }
              }
            }
          }
        }
      },
      "relatedTasks": [
        "task_1",
        "task_2",
        "task_3",
        "task_4",
        "task_5",
        "task_6"
      ]
