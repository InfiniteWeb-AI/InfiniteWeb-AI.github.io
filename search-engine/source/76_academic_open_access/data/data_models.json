{
  "entities": [
    {
      "name": "Article",
      "storage_key": "articles",
      "description": "Scholarly article with metadata, access info, metrics, and links to full text and datasets.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "name": "abstract",
          "type": "string",
          "required": false
        },
        {
          "name": "authors",
          "type": "array",
          "required": true,
          "description": "Array of author display strings in order (e.g., 'Smith J.', 'Doe A.')"
        },
        {
          "name": "journalId",
          "type": "string",
          "required": true,
          "description": "ID of the publishing journal"
        },
        {
          "name": "journalTitle",
          "type": "string",
          "required": true
        },
        {
          "name": "issueId",
          "type": "string",
          "required": false,
          "description": "ID of the journal issue containing this article"
        },
        {
          "name": "publicationDate",
          "type": "datetime",
          "required": true
        },
        {
          "name": "publicationYear",
          "type": "number",
          "required": true
        },
        {
          "name": "volume",
          "type": "string",
          "required": false
        },
        {
          "name": "issueNumber",
          "type": "string",
          "required": false
        },
        {
          "name": "pageStart",
          "type": "number",
          "required": false
        },
        {
          "name": "pageEnd",
          "type": "number",
          "required": false
        },
        {
          "name": "pageCount",
          "type": "number",
          "required": false,
          "description": "Total pages; can be derived from pageEnd - pageStart + 1 where available"
        },
        {
          "name": "articleType",
          "type": "enum",
          "required": true,
          "values": [
            "research_article",
            "clinical_trial",
            "review_article",
            "editorial",
            "commentary",
            "other"
          ]
        },
        {
          "name": "subjectAreas",
          "type": "array",
          "required": true,
          "description": "Array of subject area enum values: neuroscience, environmental_science, public_health, medicine, computer_science, cardiology"
        },
        {
          "name": "keywords",
          "type": "array",
          "required": false,
          "description": "Array of free-form keyword strings"
        },
        {
          "name": "accessType",
          "type": "enum",
          "required": true,
          "values": [
            "open_access",
            "subscription",
            "restricted"
          ]
        },
        {
          "name": "license",
          "type": "enum",
          "required": true,
          "values": [
            "cc_by",
            "cc_by_nc",
            "cc_by_sa",
            "cc_by_nd",
            "cc0",
            "other_open_license"
          ]
        },
        {
          "name": "isOpenAccess",
          "type": "boolean",
          "required": true,
          "description": "True if the article is open access"
        },
        {
          "name": "hasOpenData",
          "type": "boolean",
          "required": true,
          "description": "True if associated datasets are available (drives 'Open Data' badge)"
        },
        {
          "name": "openDataBadgeLabel",
          "type": "string",
          "required": false,
          "description": "Display label for open data badge, e.g., 'Open Data'"
        },
        {
          "name": "citationCount",
          "type": "number",
          "required": false
        },
        {
          "name": "sampleSize",
          "type": "number",
          "required": false,
          "description": "Total sample size for clinical / randomized controlled trials"
        },
        {
          "name": "downloadCount",
          "type": "number",
          "required": false
        },
        {
          "name": "doi",
          "type": "string",
          "required": false
        },
        {
          "name": "pdfUrl",
          "type": "string",
          "required": false
        },
        {
          "name": "htmlUrl",
          "type": "string",
          "required": false
        },
        {
          "name": "dataTabAvailable",
          "type": "boolean",
          "required": true,
          "description": "True if the 'Data & Materials' or 'Supplementary Data' tab should be shown"
        },
        {
          "name": "datasetIds",
          "type": "array",
          "required": false,
          "description": "Array of dataset IDs associated with this article"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": true
        }
      ]
    },
