        },
        {
          "name": "recommendedProductIds",
          "type": "array",
          "required": false,
          "description": "Array of Product.id values used for 'Customers also bought' / 'You may also like'"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": true
        }
