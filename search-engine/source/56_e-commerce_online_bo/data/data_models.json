        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "parentCategoryId",
          "type": "string",
          "required": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": true
        }
      ],
      "data_pre_generation_num": "few",
