        },
        {
          "name": "photoUrl",
          "type": "string",
          "required": false
        },
        {
          "name": "websiteUrl",
          "type": "string",
          "required": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": true
        }
      ],
      "data_pre_generation_num": "many",
