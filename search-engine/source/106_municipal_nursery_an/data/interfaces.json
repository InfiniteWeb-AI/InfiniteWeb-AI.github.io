    {
      "name": "searchNurseries",
      "description": "Search and filter nurseries for the main nursery search & results page or quick search from the homepage.",
      "parameters": [
        {
          "name": "childAgeYears",
          "type": "number",
          "required": false,
          "description": "Child age in years to match accepted age ranges and fee schedules, e.g., 3."
        },
        {
          "name": "desiredStartDate",
          "type": "string",
          "required": false,
          "description": "Desired start date as ISO date string 'YYYY-MM-DD', used for availability-related filters."
        },
        {
          "name": "maxDistanceKm",
          "type": "number",
          "required": false,
          "description": "Maximum distance from home in kilometers, e.g., 3."
        },
        {
          "name": "district",
          "type": "string",
          "required": false,
          "description": "District filter, e.g., 'north', 'east', 'downtown'."
        },
        {
          "name": "careType",
          "type": "string",
          "required": false,
          "description": "Care type to filter by, e.g., 'full_day_8h_plus', 'half_day_5h'."
        },
        {
          "name": "maxMonthlyFee",
          "type": "number",
          "required": false,
          "description": "Maximum base or schedule-specific monthly fee to include."
        },
        {
          "name": "minRating",
          "type": "number",
          "required": false,
          "description": "Minimum average rating in stars, e.g., 4.5."
        },
        {
          "name": "opensByTimeWeekday",
          "type": "string",
          "required": false,
          "description": "Latest acceptable weekday opening time 'HH:MM', e.g., '07:00'. Only nurseries opening at or before this time are returned."
        },
        {
          "name": "hasNutFreeMenu",
          "type": "boolean",
          "required": false,
          "description": "Filter to nurseries with nut-free menu if true."
        },
        {
          "name": "hasLactoseFreeOptions",
          "type": "boolean",
          "required": false,
          "description": "Filter to nurseries with lactose-free options if true."
        },
        {
          "name": "hasLargeOutdoorPlayground",
          "type": "boolean",
          "required": false,
          "description": "Filter to nurseries that have a large outdoor playground if true."
        },
        {
          "name": "sortBy",
          "type": "string",
          "required": false,
          "description": "Sort order key. Supported values: 'monthly_fee_asc', 'monthly_fee_desc', 'rating_desc', 'rating_asc', 'opening_time_asc', 'distance_asc', 'name_asc'."
        }
      ],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "nurseryId": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "district": {
              "type": "string"
            },
            "districtLabel": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "distanceFromHomeKm": {
              "type": "number"
            },
            "ratingAverage": {
              "type": "number"
            },
            "ratingCount": {
              "type": "number"
            },
            "baseMonthlyFee": {
              "type": "number"
            },
            "currency": {
              "type": "string"
            },
            "opensByTimeWeekday": {
              "type": "string",
              "description": "Earliest weekday opening time in 'HH:MM'."
            },
            "hasFullDayCare": {
              "type": "boolean"
            },
            "hasHalfDayCare": {
              "type": "boolean"
            },
            "hasLargeOutdoorPlayground": {
              "type": "boolean"
            },
            "hasNutFreeMenu": {
              "type": "boolean"
            },
            "hasLactoseFreeOptions": {
              "type": "boolean"
            },
            "estimatedMonthlyFeeForCriteria": {
              "type": "number",
              "description": "If child age and careType were provided, this is the matching monthly fee."
            },
            "isFavorite": {
              "type": "boolean",
              "description": "True if this nursery is in the user's favorites list."
            }
          }
        }
      },
      "relatedTasks": [
        "task_1",
        "task_2",
        "task_6",
        "task_7"
