    {
      "name": "searchProviders",
      "description": "Search for providers matching a query, location, and filters for the search results and map view.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": false,
          "description": "Search keyword, e.g., 'iphone 12 screen repair', 'laptop data recovery'"
        },
        {
          "name": "location_text",
          "type": "string",
          "required": false,
          "description": "Optional explicit location override, e.g., '10001', 'San Francisco, CA'. If omitted, uses current location."
        },
        {
          "name": "distance_miles_max",
          "type": "number",
          "required": false,
          "description": "Max search radius in miles, e.g., 3, 10, 20, 25"
        },
        {
          "name": "rating_min",
          "type": "number",
          "required": false,
          "description": "Minimum average provider rating, e.g., 4.0, 4.5"
        },
        {
          "name": "service_code",
          "type": "string",
          "required": false,
          "description": "Primary service code filter, e.g., 'smartphone_screen_repair', 'laptop_battery_replacement', 'console_hdmi_port_repair'"
        },
        {
          "name": "service_category_id",
          "type": "string",
          "required": false,
          "description": "Optional category filter from Browse Categories",
          "entityReference": {
            "entity": "ServiceCategory",
            "displayField": "name",
            "valueField": "id"
          }
        },
        {
          "name": "price_filter",
          "type": "object",
          "required": false,
          "properties": {
            "service_code": {
              "type": "string",
              "description": "Service whose price to cap, e.g., 'smartphone_screen_repair', 'laptop_battery_replacement', 'tablet_charging_port_repair', 'laptop_data_recovery'"
            },
            "max_price": {
              "type": "number",
              "description": "Maximum price for the given service_code, e.g., 200, 120, 90, 400"
            }
          }
        },
        {
          "name": "visit_type_filters",
          "type": "object",
          "required": false,
          "properties": {
            "in_store": {
              "type": "boolean"
            },
            "home_visit": {
              "type": "boolean"
            },
            "pickup_delivery": {
              "type": "boolean"
            },
            "free_pickup": {
              "type": "boolean"
            }
          }
        },
        {
          "name": "availability_filters",
          "type": "object",
          "required": false,
          "properties": {
            "open_on_day_of_week": {
              "type": "string",
              "description": "Day constraint, e.g., 'saturday'"
            },
            "close_after_time": {
              "type": "string",
              "description": "Required closing time (24h HH:MM), e.g., '17:00'"
            },
            "require_24_7": {
              "type": "boolean",
              "description": "Only show providers that are 24/7"
            },
            "require_emergency_service": {
              "type": "boolean",
              "description": "Only show providers that offer emergency service"
            }
          }
        },
        {
          "name": "fee_filters",
          "type": "object",
          "required": false,
          "properties": {
            "require_free_diagnostic": {
              "type": "boolean"
            },
            "require_no_diagnostic_fee": {
              "type": "boolean"
            },
            "require_no_fix_no_fee": {
              "type": "boolean"
            }
          }
        },
        {
          "name": "sort_by",
          "type": "string",
          "required": false,
          "description": "Sort option, e.g., 'rating_desc', 'price_asc', 'distance_asc', 'relevance'"
        },
        {
          "name": "view_mode",
          "type": "string",
          "required": false,
          "description": "Result view mode, e.g., 'list', 'map', 'both'"
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "description": "Page number for paginated results (1-based)"
        },
        {
          "name": "page_size",
          "type": "number",
          "required": false,
          "description": "Number of providers per page"
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "providers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "provider": {
                  "type": "Provider"
                },
                "matched_services": {
                  "type": "array",
                  "items": "ProviderService"
                },
                "distance_miles": {
                  "type": "number"
                },
                "lowest_price_for_filtered_service": {
                  "type": "number"
                },
                "highest_price_for_filtered_service": {
                  "type": "number"
                },
                "is_favorite": {
                  "type": "boolean"
                }
              }
            }
          },
          "total_results": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "page_size": {
            "type": "number"
          },
          "applied_filters_summary": {
            "type": "object",
            "properties": {
              "location_display_name": {
                "type": "string"
              },
              "distance_miles_max": {
                "type": "number"
              },
              "rating_min": {
                "type": "number"
              },
              "sort_by": {
                "type": "string"
              }
            }
          },
          "map_pins": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "providerId": {
                  "type": "string"
                },
                "latitude": {
                  "type": "number"
                },
                "longitude": {
                  "type": "number"
                },
                "distance_miles": {
                  "type": "number"
                },
                "name": {
                  "type": "string"
                },
                "rating_average": {
                  "type": "number"
                },
                "rating_count": {
                  "type": "number"
                },
                "is_favorite": {
                  "type": "boolean"
                }
              }
            }
          },
          "compare_selection_count": {
            "type": "number"
          }
        }
      },
      "relatedTasks": [
        "task_1",
        "task_2",
        "task_3",
        "task_4",
        "task_6",
        "task_7",
        "task_8"
      ]
    },
