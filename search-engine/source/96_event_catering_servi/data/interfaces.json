    {
      "name": "listPackages",
      "description": "List catering packages for a given category with optional filters for guest count, price, dietary flags, meal type, and sorting.",
      "parameters": [
        {
          "name": "categoryCode",
          "type": "string",
          "required": true,
          "description": "Primary package category to list",
          "enum": [
            "corporate_events",
            "weddings",
            "parties_birthdays",
            "coffee_breaks",
            "all_events"
          ]
        },
        {
          "name": "guestCount",
          "type": "number",
          "required": false,
          "description": "Optional guest count to estimate total price (e.g., 25, 40, 50, 60, 80, 120)"
        },
        {
          "name": "pricePerPersonMin",
          "type": "number",
          "required": false
        },
        {
          "name": "pricePerPersonMax",
          "type": "number",
          "required": false
        },
        {
          "name": "mealType",
          "type": "string",
          "required": false,
          "enum": [
            "breakfast",
            "brunch",
            "lunch",
            "dinner",
            "coffee_break",
            "reception",
            "other"
          ]
        },
        {
          "name": "serviceStyle",
          "type": "string",
          "required": false,
          "enum": [
            "buffet",
            "plated",
            "family_style",
            "stations",
            "drop_off",
            "other"
          ]
        },
        {
          "name": "includesDessert",
          "type": "boolean",
          "required": false
        },
        {
          "name": "courseCount",
          "type": "number",
          "required": false,
          "description": "Exact course count to filter by (e.g., 3 for 3-course dinners)"
        },
        {
          "name": "vegetarianOnly",
          "type": "boolean",
          "required": false,
          "description": "If true, show only vegetarian-friendly packages"
        },
        {
          "name": "glutenFreeFriendly",
          "type": "boolean",
          "required": false
        },
        {
          "name": "sortBy",
          "type": "string",
          "required": false,
          "enum": [
            "price_low_to_high",
            "price_high_to_low",
            "rating",
            "name"
          ]
        }
      ],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "package": {
              "type": "Package"
            },
            "categoryName": {
              "type": "string"
            },
            "displayPricePerPerson": {
              "type": "number"
            },
            "estimatedTotalForGuestCount": {
