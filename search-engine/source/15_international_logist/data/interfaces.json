    {
      "name": "createShipmentQuote",
      "description": "Create a shipment quote for a given origin, destination, package, and shipment date, optionally in 'quote' or 'create_shipment' mode, and return available service rate options.",
      "parameters": [
        {
          "name": "mode",
          "type": "string",
          "required": true,
          "description": "Quote mode; 'quote' for pricing only, 'create_shipment' when starting a shipment flow.",
          "enum": [
            "quote",
            "create_shipment"
          ]
        },
        {
          "name": "origin_city",
          "type": "string",
          "required": true
        },
        {
          "name": "origin_postal_code",
          "type": "string",
          "required": true
        },
        {
          "name": "origin_country",
          "type": "string",
          "required": true
        },
        {
          "name": "destination_city",
          "type": "string",
          "required": true
        },
        {
          "name": "destination_postal_code",
          "type": "string",
          "required": true
        },
        {
          "name": "destination_country",
          "type": "string",
          "required": true
        },
        {
          "name": "package_type",
          "type": "string",
          "required": true,
          "description": "e.g., 'box', 'documents'",
          "enum": [
            "box",
            "envelope",
            "documents",
            "tube",
            "pallet",
            "other"
          ]
        },
        {
          "name": "shipment_type",
          "type": "string",
          "required": true,
          "description": "e.g., 'documents', 'parcel'",
          "enum": [
            "documents",
            "parcel",
            "freight",
            "other"
          ]
        },
        {
          "name": "weight",
          "type": "number",
          "required": true
        },
        {
          "name": "weight_unit",
          "type": "string",
          "required": true,
          "enum": [
            "kg",
            "lb"
          ]
        },
        {
          "name": "length",
          "type": "number",
          "required": false
        },
        {
          "name": "width",
          "type": "number",
          "required": false
        },
        {
          "name": "height",
          "type": "number",
          "required": false
        },
        {
          "name": "dimension_unit",
          "type": "string",
          "required": false,
          "enum": [
            "cm",
            "in"
          ]
        },
        {
          "name": "shipment_date",
          "type": "string",
          "required": true,
          "description": "ISO 8601 date-time string for the planned shipment date."
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "quote": "ShipmentQuote",
          "rate_options": {
            "type": "array",
            "items": "ShippingRateOption"
          }
        }
      },
      "relatedTasks": [
        "task_1",
        "task_2",
        "task_7",
        "task_8"
      ]
    },
