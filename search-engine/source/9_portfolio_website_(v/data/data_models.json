{
  "entities": [
    {
      "name": "Artwork",
      "storage_key": "artworks",
      "description": "Portfolio artwork record used in the Gallery, Favorites, Wishlist, and to power some Shop product metadata.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "name": "category",
          "type": "enum",
          "required": true,
          "values": [
            "landscape",
            "cityscape",
            "portrait",
            "abstract",
            "still_life",
            "figure",
            "other"
          ]
        },
        {
          "name": "year",
          "type": "number",
          "required": true,
          "description": "Creation year used for gallery filters like '2022 or later'"
        },
        {
          "name": "medium",
          "type": "enum",
          "required": true,
          "values": [
            "acrylic_on_canvas",
            "oil_on_canvas",
            "watercolor_on_paper",
            "digital",
            "mixed_media",
            "ink_on_paper",
            "other"
          ]
        },
        {
          "name": "color_palette",
          "type": "enum",
          "required": true,
          "values": [
            "pastel",
            "vibrant",
            "monochrome",
            "neutral",
            "earth_tones",
            "other"
          ]
        },
        {
          "name": "width_cm",
          "type": "number",
          "required": true
        },
        {
          "name": "height_cm",
          "type": "number",
          "required": true
        },
        {
          "name": "depth_cm",
          "type": "number",
          "required": false
        },
        {
          "name": "price",
          "type": "number",
          "required": false,
          "description": "Displayed in gallery when applicable; used for price filters like 'under $300' or 'under $200'."
        },
        {
          "name": "is_for_sale",
          "type": "boolean",
          "required": true,
          "description": "Whether the artwork is currently offered for sale."
        },
        {
          "name": "sale_kind",
          "type": "enum",
          "required": true,
          "values": [
            "original",
            "print",
            "original_and_print",
            "not_for_sale"
          ]
        },
        {
          "name": "shop_category",
          "type": "enum",
          "required": false,
          "values": [
            "prints",
            "originals",
            "none"
          ],
          "description": "Links portfolio artwork to a shop category; includes URL param-compatible values 'prints' and 'originals'."
        },
        {
          "name": "main_image_url",
          "type": "string",
          "required": true
        },
        {
          "name": "additional_image_urls",
          "type": "array",
          "required": false,
          "description": "Array of extra image URLs"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "is_featured",
          "type": "boolean",
          "required": true,
          "description": "Used on home page featured artworks sections."
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "required": true
        }
      ]
    },
    {
