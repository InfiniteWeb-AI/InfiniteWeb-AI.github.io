{
  "entities": [
    {
      "name": "Activity",
      "storage_key": "activities",
      "description": "Any listed thing a family can attend: events, classes, workshops, seasonal/holiday activities, playground/storytime map items.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "name": "subtitle",
          "type": "string",
          "required": false
        },
        {
          "name": "short_description",
          "type": "string",
          "required": false
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "content_group",
          "type": "enum",
          "required": true,
          "values": [
            "events",
            "classes_programs",
            "workshops_camps",
            "seasonal_holiday"
          ],
          "description": "Top-level context used by header links and browse categoryId."
        },
        {
          "name": "activity_category",
          "type": "enum",
          "required": true,
          "values": [
            "indoor",
            "outdoor",
            "parks_playgrounds",
            "playground",
            "storytime",
            "shows_performances"
          ],
          "description": "Category used by filters like Indoor, Parks & Playgrounds, Shows & Performances, Playground, Storytime."
        },
        {
          "name": "min_age",
          "type": "number",
          "required": false,
          "description": "Minimum recommended age in years (e.g., 5)."
        },
        {
          "name": "max_age",
          "type": "number",
          "required": false,
          "description": "Maximum recommended age in years (e.g., 8)."
        },
        {
          "name": "price_type",
          "type": "enum",
          "required": true,
          "values": [
            "free",
            "paid",
            "donation"
          ],
          "description": "Used to support 'Free only' filtering."
        },
        {
          "name": "price_min",
          "type": "number",
          "required": false,
          "description": "Lowest ticket price for this activity (per unit defined by price_unit)."
        },
        {
          "name": "price_max",
          "type": "number",
          "required": false,
          "description": "Highest ticket price for this activity, used for max price filters."
        },
        {
          "name": "price_currency",
          "type": "string",
          "required": false,
          "description": "Currency code, e.g., 'USD'."
        },
        {
          "name": "price_unit",
          "type": "enum",
          "required": false,
          "values": [
            "per_ticket",
            "per_family",
            "per_group"
          ],
          "description": "Unit for price values; supports 'per ticket' wording in tasks."
        },
        {
          "name": "schedule_recurrence",
          "type": "enum",
          "required": false,
          "values": [
            "one_time",
            "weekly",
            "multi_day",
            "seasonal"
          ],
          "description": "Supports 'Schedule – Weekly' filter for classes/programs."
        },
        {
          "name": "first_start_datetime",
          "type": "datetime",
          "required": false,
          "description": "Start of first occurrence; helps date-based browsing."
        },
        {
          "name": "last_end_datetime",
          "type": "datetime",
          "required": false,
          "description": "End of last occurrence; supports date-range filters like Dec 20–24."
        },
        {
          "name": "location_id",
          "type": "string",
          "required": true,
          "description": "Links to Location for distance and map view."
        },
        {
          "name": "tags",
          "type": "array",
          "required": false,
          "description": "Array of tag enums for filters like Holiday and Free parking. Values: holiday, free_parking."
        },
        {
          "name": "accessibility_features",
          "type": "array",
          "required": false,
          "description": "Array of accessibility enums, e.g., sensory_friendly, stroller_friendly."
        },
        {
          "name": "rating",
          "type": "number",
          "required": false,
          "description": "Average star rating (0–5, supports 4.5+ filter)."
        },
        {
          "name": "rating_count",
          "type": "number",
          "required": false,
          "description": "Number of ratings; useful for display and sorting."
        },
        {
          "name": "is_featured",
          "type": "boolean",
          "required": false,
          "description": "Used on home page highlights."
        },
        {
          "name": "image_url",
          "type": "string",
          "required": false
        },
        {
          "name": "booking_required",
          "type": "boolean",
          "required": false,
          "description": "Indicates whether any registration is required."
        },
        {
          "name": "registration_available",
          "type": "boolean",
          "required": false,
          "description": "Controls visibility of 'Register' / 'Book Now' button."
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "ActivitySession",
      "storage_key": "activity_sessions",
      "description": "Individual dated occurrences/time slots for an activity used for date, time-of-day, and registration.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "activity_id",
          "type": "string",
          "required": true
        },
        {
          "name": "start_datetime",
          "type": "datetime",
          "required": true
        },
        {
          "name": "end_datetime",
          "type": "datetime",
          "required": false
        },
        {
          "name": "day_of_week",
          "type": "enum",
          "required": true,
          "values": [
            "monday",
            "tuesday",
            "wednesday",
            "thursday",
            "friday",
            "saturday",
            "sunday"
          ],
          "description": "Supports 'Day of week' filter (Saturday, weekdays)."
        },
        {
          "name": "time_of_day_bucket",
          "type": "enum",
          "required": true,
          "values": [
            "morning",
            "afternoon",
            "evening",
            "daytime",
            "after_4pm"
          ],
          "description": "Supports 'Morning (before 12 PM)', 'Afternoon (12–5 PM)', 'Evening (after 5 PM)', 'Daytime (before 5 PM)', 'After 4 PM' filters."
        },
        {
          "name": "is_weekend",
          "type": "boolean",
          "required": false,
          "description": "Helps implement 'This Weekend' shortcut."
        },
        {
          "name": "capacity_total",
          "type": "number",
          "required": false
        },
        {
          "name": "capacity_available",
          "type": "number",
          "required": false
        },
        {
          "name": "is_registration_open",
          "type": "boolean",
          "required": false
        }
      ]
    },
    {
      "name": "Location",
      "storage_key": "locations",
      "description": "Physical place where activities occur; supports distance filters and map view.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Venue or place name, e.g., 'Riverside Park'."
        },
        {
          "name": "address_line1",
          "type": "string",
          "required": false
        },
        {
          "name": "address_line2",
          "type": "string",
          "required": false
        },
        {
          "name": "city",
          "type": "string",
          "required": false
        },
        {
          "name": "state",
          "type": "string",
          "required": false
        },
        {
          "name": "postal_code",
          "type": "string",
          "required": false
        },
        {
          "name": "neighborhood",
          "type": "string",
          "required": false,
          "description": "Neighborhood label used by map search, e.g., 'Riverside Park'."
        },
        {
          "name": "latitude",
          "type": "number",
          "required": true
        },
        {
          "name": "longitude",
          "type": "number",
          "required": true
        },
        {
          "name": "has_free_parking",
          "type": "boolean",
          "required": false,
          "description": "Supports 'Free parking' badge/tag."
        },
        {
          "name": "parking_details",
          "type": "string",
          "required": false
        },
        {
          "name": "indoor_outdoor_type",
          "type": "enum",
          "required": false,
          "values": [
            "indoor",
            "outdoor",
            "mixed"
          ],
          "description": "Can support some Indoor/Outdoor logic when tied to place rather than activity."
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "Membership",
