    {
      "name": "getCategoryProducts",
      "description": "Retrieve a paginated list of products for a specific category, applying filters and sorting for category listing pages.",
      "parameters": [
        {
          "name": "category_code",
          "type": "string",
          "required": true,
          "description": "Category code to browse, e.g., 'office_chairs', 'paper_media', 'monitors', 'cleaning_supplies', 'analytics'."
        },
        {
          "name": "filters",
          "type": "object",
          "required": false,
          "properties": {
            "min_price": {
              "type": "number"
            },
            "max_price": {
              "type": "number"
            },
            "min_rating": {
              "type": "number"
            },
            "product_type": {
              "type": "string",
              "description": "Optional product_type filter, e.g., 'office_chair', 'paper', 'monitor', 'cleaning_product'."
            },
            "chair_type": {
              "type": "string",
              "description": "Filter ergonomic chairs etc., e.g., 'ergonomic', 'task_chair'."
            },
            "paper_size": {
              "type": "string",
              "description": "Paper size filter, e.g., 'a4'."
            },
            "screen_size_inches": {
              "type": "number"
            },
            "printer_technology": {
              "type": "string",
              "description": "Printer technology, e.g., 'laser'."
            },
            "is_color_printing": {
              "type": "boolean"
            },
            "has_duplex_printing": {
              "type": "boolean"
            },
            "has_wifi_connectivity": {
              "type": "boolean"
            },
            "is_eco_certified": {
              "type": "boolean"
            },
            "has_free_shipping": {
              "type": "boolean"
            },
            "compatible_with_model": {
              "type": "string",
              "description": "Compatibility filter based on compatible device model, e.g., 'ProBook 450'."
            }
          }
        },
        {
          "name": "sort_by",
          "type": "string",
          "required": false,
          "description": "Sort order for products.",
          "values": [
            "relevance",
            "price_low_to_high",
            "price_high_to_low",
            "rating_high_to_low",
            "rating_low_to_high"
          ]
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "page_size",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "category": "Category",
          "products": {
            "type": "array",
            "items": "Product"
          },
          "total_count": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "page_size": {
            "type": "number"
          },
          "available_sorts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
