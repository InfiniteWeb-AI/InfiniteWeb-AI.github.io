    {
      "name": "searchTyresBySizeAndFilters",
      "description": "Search for tyres by size and optional filters (season, performance, price, rating, benefits, etc.), returning a paginated result set for the tyre listing page.",
      "parameters": [
        {
          "name": "width",
          "type": "number",
          "required": true,
          "description": "Tyre width, e.g., 205"
        },
        {
          "name": "profile",
          "type": "number",
          "required": true,
          "description": "Tyre profile/aspect ratio, e.g., 55"
        },
        {
          "name": "rim_diameter",
          "type": "number",
          "required": true,
          "description": "Rim diameter in inches, e.g., 16"
        },
        {
          "name": "filters",
          "type": "object",
          "required": false,
          "properties": {
            "season": {
              "type": "string",
              "description": "Filter by season/type, e.g., 'winter', 'summer', 'all_season'"
            },
            "performance_category": {
              "type": "string",
              "description": "Filter by performance/usage, e.g., 'performance', 'sport', 'standard'"
            },
            "brand_tier": {
              "type": "string",
              "description": "Filter by brand tier, e.g., 'budget', 'mid_range', 'premium'"
            },
            "has_free_fitting": {
              "type": "boolean",
              "description": "If true, only return tyres with free fitting"
            },
            "min_price": {
              "type": "number",
              "description": "Minimum price per tyre"
            },
            "max_price": {
              "type": "number",
              "description": "Maximum price per tyre"
            },
            "min_customer_rating": {
              "type": "number",
              "description": "Minimum average customer rating, e.g., 4 or 4.5"
            },
            "min_customer_rating_count": {
              "type": "number",
              "description": "Minimum number of reviews if used to filter"
            },
            "min_speed_rating": {
              "type": "string",
              "description": "Minimum speed rating code, e.g., 'w' to include 'w','y','zr'"
            },
            "max_noise_db": {
              "type": "number",
              "description": "Maximum external noise level in dB"
            },
            "fuel_efficiency_ratings": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Allowed fuel efficiency ratings, e.g., ['a','b']"
            },
            "only_available": {
              "type": "boolean",
              "description": "If true, only return products where is_available = true"
            }
          }
        },
        {
          "name": "sort",
          "type": "string",
          "required": false,
          "description": "Sort order code, e.g., 'customer_rating_desc', 'price_asc', 'price_desc', 'noise_asc'"
        },
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "page_size",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "tyres": {
            "type": "array",
            "items": "TyreProduct",
            "description": "Tyre products matching the search"
          },
          "brands": {
            "type": "array",
            "items": "Brand",
            "description": "Brands corresponding to returned tyres for display of brand names/logos"
          },
          "total_results": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "page_size": {
            "type": "number"
          },
          "applied_filters": {
            "type": "object",
            "properties": {
              "season": {
                "type": "string"
              },
              "performance_category": {
                "type": "string"
              },
              "brand_tier": {
                "type": "string"
              },
              "has_free_fitting": {
                "type": "boolean"
              },
              "min_price": {
                "type": "number"
              },
              "max_price": {
                "type": "number"
              },
              "min_customer_rating": {
                "type": "number"
              },
              "min_speed_rating": {
                "type": "string"
              },
              "max_noise_db": {
                "type": "number"
              },
              "fuel_efficiency_ratings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "only_available": {
                "type": "boolean"
              },
              "sort": {
                "type": "string"
              }
            }
          }
        }
