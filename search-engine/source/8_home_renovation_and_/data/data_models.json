{
  "entities": [
    {
      "name": "Package",
      "storage_key": "packages",
      "description": "Renovation and extension packages (extensions, kitchens, bathrooms, etc.) shown in listings, details, comparison, and shortlist.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "slug",
          "type": "string",
          "required": false,
          "description": "URL-friendly identifier"
        },
        {
          "name": "category_id",
          "type": "enum",
          "required": true,
          "values": [
            "extensions",
            "kitchen_renovations",
            "bathroom_renovations"
          ],
          "description": "Matches categoryId in package listing URLs"
        },
        {
          "name": "project_type",
          "type": "enum",
          "required": true,
          "values": [
            "rear_extension",
            "deck_extension",
            "loft_conversion",
            "kitchen_renovation",
            "bathroom_renovation",
            "full_home_renovation",
            "other"
          ],
          "description": "High-level project type this package belongs to"
        },
        {
          "name": "extension_type",
          "type": "enum",
          "required": false,
          "values": [
            "rear_extension",
            "side_extension",
            "wraparound_extension",
            "loft_conversion",
            "deck_extension",
            "not_applicable"
          ],
          "description": "Specific extension subtype used in Extensions filters"
        },
        {
          "name": "price",
          "type": "number",
          "required": true,
          "description": "Package base price"
        },
        {
          "name": "size_sqm",
          "type": "number",
          "required": false,
          "description": "Overall package size in square meters (used for filters like 20–30 sqm)"
        },
        {
          "name": "added_floor_area_sqm",
          "type": "number",
          "required": false,
          "description": "Added floor area in sqm for extensions; used in comparisons"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "inclusions",
          "type": "array",
          "required": false,
          "description": "List of inclusion bullet points for this package"
        },
        {
          "name": "images",
          "type": "array",
          "required": false,
          "description": "Array of image URLs or objects for gallery on detail page"
        },
        {
          "name": "rating",
          "type": "number",
          "required": false,
          "description": "Optional average user rating for the package"
        },
        {
          "name": "is_featured",
          "type": "boolean",
          "required": false,
          "description": "Whether this package is highlighted on the homepage"
        },
        {
          "name": "is_active",
          "type": "boolean",
          "required": true,
          "description": "Whether this package is available to be shown and requested"
