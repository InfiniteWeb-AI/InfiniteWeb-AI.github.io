{
  "entities": [
    {
      "name": "Book",
      "storage_key": "books",
      "description": "Single book entry in the catalog (one record per title/format combination) used for browsing, filtering, reviews, lists, bundles, cart, and comparisons.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "name": "subtitle",
          "type": "string",
          "required": false
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "genre",
          "type": "enum",
          "required": true,
          "values": [
            "all",
            "fantasy",
            "science_fiction",
            "young_adult",
            "mystery",
            "non_fiction",
            "romance",
            "thriller",
            "horror",
            "literary_fiction",
            "poetry",
            "children",
            "other"
          ]
        },
        {
          "name": "work_type",
          "type": "enum",
          "required": true,
          "values": [
            "novel",
            "short_story",
            "novella",
            "collection",
            "novelette",
            "non_fiction"
          ]
        },
        {
          "name": "format",
          "type": "enum",
          "required": true,
          "values": [
            "ebook",
            "paperback",
            "hardcover",
            "audiobook"
          ]
        },
        {
          "name": "price",
          "type": "number",
          "required": true
        },
        {
          "name": "currency",
          "type": "string",
          "required": true
        },
        {
          "name": "rating",
          "type": "number",
          "required": true,
          "description": "Average star rating from 0.0 to 5.0 used for rating filters and sorting"
        },
        {
          "name": "rating_count",
          "type": "number",
          "required": true,
          "description": "Number of ratings used with rating to determine reliability"
        },
        {
          "name": "page_count",
          "type": "number",
          "required": true,
          "description": "Total number of pages; used for comparison and short-work filters"
        },
        {
          "name": "publication_date",
          "type": "datetime",
          "required": true,
          "description": "Publication date used for date-range filters and newest-first sorting"
        },
        {
          "name": "is_featured",
          "type": "boolean",
          "required": false,
          "description": "Marks books that should be highlighted on the homepage"
        },
        {
          "name": "cover_image_url",
          "type": "string",
          "required": false
        },
        {
          "name": "keywords",
          "type": "array",
          "required": false,
          "description": "Array of strings for search indexing (e.g., ['mystery', 'detective'])"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": false
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "Review",
      "storage_key": "reviews",
      "description": "Individual user-submitted review for a book, including star rating and text.",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "bookId",
          "type": "string",
          "required": true
        },
        {
          "name": "rating",
          "type": "number",
          "required": true,
          "description": "Star rating value (1–5)"
        },
        {
          "name": "title",
          "type": "string",
          "required": false
        },
        {
          "name": "body",
          "type": "string",
          "required": true
        },
        {
          "name": "reviewer_name",
          "type": "string",
          "required": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        }
      ]
    },
    {
      "name": "LibraryList",
      "storage_key": "library_lists",
      "description": "Generic list in the personal library, including reading lists, wishlists, favorites, and saved-article lists.",
      "data_pre_generation_num": "few",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "User-visible name, e.g., 'Main Reading List', 'Summer 2025', 'Articles to Read'"
        },
        {
          "name": "list_type",
          "type": "enum",
          "required": true,
          "values": [
            "book_reading_list",
            "book_wishlist",
            "article_reading_list",
            "favorites"
          ]
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "is_default",
          "type": "boolean",
          "required": true,
          "description": "True for system-default lists like the main reading list or favorites"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "LibraryListItem",
      "storage_key": "library_list_items",
      "description": "Item saved into a library list, referencing either a book or a blog article.",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "listId",
          "type": "string",
          "required": true
        },
        {
          "name": "item_type",
          "type": "enum",
          "required": true,
          "values": [
            "book",
            "article"
          ]
        },
        {
          "name": "bookId",
          "type": "string",
          "required": false,
          "description": "Set when item_type = 'book'"
        },
        {
          "name": "articleId",
          "type": "string",
          "required": false,
          "description": "Set when item_type = 'article' (BlogPost)"
        },
        {
          "name": "addedAt",
          "type": "datetime",
          "required": true,
          "description": "When this item was added to the list"
        }
      ]
    },
    {
      "name": "CompareSet",
      "storage_key": "compare_sets",
      "description": "A comparison context for books selected on the catalog page, shown side-by-side.",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": false,
          "description": "Optional label, e.g., 'current_compare'"
        },
        {
          "name": "is_active",
          "type": "boolean",
          "required": true,
          "description": "True for the currently used compare set"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "CompareSetItem",
      "storage_key": "compare_set_items",
      "description": "A single book included in a compare set.",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "compareSetId",
          "type": "string",
          "required": true
        },
        {
          "name": "bookId",
          "type": "string",
          "required": true
        },
        {
          "name": "addedAt",
          "type": "datetime",
          "required": true,
          "description": "When the book was added to the compare set"
        }
      ]
    },
    {
      "name": "Bundle",
      "storage_key": "bundles",
      "description": "Custom eBook bundle composed of multiple books before being added to the cart.",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": false,
          "description": "Optional bundle name shown in the cart"
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "total_price",
          "type": "number",
          "required": true,
          "description": "Cached sum of bundle item prices for quick cart display"
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "BundleItem",
      "storage_key": "bundle_items",
      "description": "A book included in a bundle with a specified quantity.",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "bundleId",
          "type": "string",
          "required": true
        },
        {
          "name": "bookId",
          "type": "string",
          "required": true
        },
        {
          "name": "quantity",
          "type": "number",
          "required": true,
          "description": "Number of copies of this book in the bundle (usually 1)"
        }
      ]
    },
    {
      "name": "Cart",
      "storage_key": "cart",
      "description": "Shopping cart for the single user, containing individual books and/or bundles.",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true,
          "description": "When the cart was first created"
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
    {
      "name": "CartItem",
      "storage_key": "cart_items",
      "description": "Item within the shopping cart, referencing either a single book or a bundle.",
      "data_pre_generation_num": "none",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "cartId",
          "type": "string",
          "required": true
        },
        {
          "name": "item_type",
          "type": "enum",
          "required": true,
          "values": [
            "book",
            "bundle"
          ]
        },
        {
          "name": "bookId",
          "type": "string",
          "required": false,
          "description": "Set when item_type = 'book'"
        },
        {
          "name": "bundleId",
          "type": "string",
          "required": false,
          "description": "Set when item_type = 'bundle'"
        },
        {
          "name": "quantity",
          "type": "number",
          "required": true,
          "description": "Number of this item in the cart"
        },
        {
          "name": "unit_price",
          "type": "number",
          "required": true,
          "description": "Price per unit at time of adding to cart"
        },
        {
          "name": "total_price",
          "type": "number",
          "required": true,
          "description": "quantity × unit_price, cached for quick display"
        },
        {
          "name": "addedAt",
          "type": "datetime",
          "required": true,
          "description": "When the item was added to the cart"
        }
      ]
    },
    {
      "name": "Event",
      "storage_key": "events",
      "description": "Author event or appearance, including online and in-person events shown in the calendar and list.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "start_datetime",
          "type": "datetime",
          "required": true,
          "description": "Event start date and time; used for month filtering and earliest-first sorting"
        },
        {
          "name": "end_datetime",
          "type": "datetime",
          "required": false,
          "description": "Optional end date/time"
        },
        {
          "name": "event_type",
          "type": "enum",
          "required": true,
          "values": [
            "online",
            "in_person",
            "hybrid"
          ]
        },
        {
          "name": "location",
          "type": "string",
          "required": false,
          "description": "Physical venue or description such as 'Online'"
        },
        {
          "name": "online_access_link",
          "type": "string",
          "required": false,
          "description": "URL or instructions for joining online events"
        },
        {
          "name": "timezone",
          "type": "string",
          "required": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": false
        }
      ]
    },
