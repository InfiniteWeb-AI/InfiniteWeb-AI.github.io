          "required": true,
          "values": [
            "submitted",
            "confirmed",
            "canceled"
          ]
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true
        }
      ]
    },
    {
      "name": "BlogPost",
      "storage_key": "blog_posts",
      "description": "Blog article/post on the site, including writing process posts and others, with tags and comment count.",
      "data_pre_generation_num": "many",
      "fields": [
        {
          "name": "id",
          "type": "string",
          "primary_key": true,
          "required": true
        },
        {
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "name": "slug",
          "type": "string",
          "required": true
        },
        {
          "name": "excerpt",
          "type": "string",
          "required": false
        },
        {
          "name": "content",
          "type": "string",
          "required": true
        },
        {
          "name": "published_at",
          "type": "datetime",
          "required": true,
          "description": "Publication date/time used for newest-first sorting"
        },
        {
          "name": "tags",
          "type": "array",
          "required": false,
          "description": "Array of tag slugs, e.g., ['writing_process', 'craft']"
        },
        {
          "name": "comment_count",
          "type": "number",
          "required": true,
