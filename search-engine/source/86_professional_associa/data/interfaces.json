    {
      "name": "searchEvents",
      "description": "Search and filter events (workshops and competitions) for the Events listing page.",
      "parameters": [
        {
          "name": "eventType",
          "type": "string",
          "required": false,
          "description": "e.g., 'workshops', 'competitions'"
        },
        {
          "name": "workshopType",
          "type": "string",
          "required": false,
          "description": "e.g., 'Lead Climbing Safety'"
        },
        {
          "name": "discipline",
          "type": "string",
          "required": false,
          "description": "e.g., 'bouldering', 'lead_climbing'"
        },
        {
          "name": "skillLevel",
          "type": "string",
          "required": false,
          "description": "e.g., 'beginner', 'intermediate', 'advanced', 'all_levels'"
        },
        {
          "name": "startDate",
          "type": "string",
          "required": false,
          "description": "Filter start date (ISO 8601, e.g., '2025-05-01')."
        },
        {
          "name": "endDate",
          "type": "string",
          "required": false,
          "description": "Filter end date (ISO 8601)."
        },
        {
          "name": "state",
          "type": "string",
          "required": false,
          "description": "2-letter state code, e.g., 'CO'."
        },
        {
          "name": "city",
          "type": "string",
          "required": false,
          "description": "City name for radius-based search, e.g., 'Seattle, WA'."
        },
        {
          "name": "radiusMiles",
          "type": "number",
          "required": false,
          "description": "Search radius in miles around the city, e.g., 100."
        },
        {
          "name": "minPrice",
          "type": "number",
          "required": false
        },
        {
          "name": "maxPrice",
          "type": "number",
          "required": false
        },
        {
          "name": "sortBy",
          "type": "string",
          "required": false,
          "default": "date_soonest_first",
          "description": "e.g., 'date_soonest_first', 'registration_fee_low_to_high', 'registration_fee_high_to_low'"
        },
        {
          "name": "limit",
          "type": "number",
          "required": false,
          "default": 50
        },
        {
          "name": "offset",
          "type": "number",
          "required": false,
          "default": 0
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": "Event"
          },
          "totalCount": {
            "type": "number"
          }
        }
      },
      "relatedTasks": [
        "task_1",
        "task_6"
      ]
    },
